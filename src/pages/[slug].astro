---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CountryBriefing from '../components/CountryBriefing.astro';
import { countries } from '../data/index.js';

export function getStaticPaths() {
  return countries.filter(c => c.live).map(c => ({ params: { slug: c.slug }, props: { country: c } }));
}
const { country } = Astro.props;
// If this country has a live pet-import spoke, surface a distinct relocation callout
// on the money guide (separate from the auto-generated "Going deeper" list). Data-driven,
// so it appears on its own for any country that gains a pets spoke.
const petSpoke = (country.spokes || []).find(s => s.topic === 'pets' && s.live !== false);
---
<Base title={country.title} description={country.description}>
  <Nav />
  <main class="wrap">
    <CountryBriefing country={country} />
    {petSpoke && (
      <section class="petcta">
        <span class="petcta-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><ellipse cx="6.4" cy="10.2" rx="1.9" ry="2.5"/><ellipse cx="10.1" cy="7.5" rx="1.9" ry="2.6"/><ellipse cx="13.9" cy="7.5" rx="1.9" ry="2.6"/><ellipse cx="17.6" cy="10.2" rx="1.9" ry="2.5"/><path d="M12 11.3c-2.8 0-5.1 2-5.1 4.4 0 1.9 1.7 3 3.5 2.6.6-.13 1.1-.19 1.6-.19s1 .06 1.6.19c1.8.4 3.5-.7 3.5-2.6 0-2.4-2.3-4.4-5.1-4.4z"/></svg></span>
        <span class="petcta-tx">
          <span class="petcta-h">Moving to {country.name} with a pet?</span>
          <span class="petcta-p">This guide is about the money side of a trip. If you are relocating rather than just visiting, bringing a dog or cat is a separate project with its own lead time and cost. We walk through the official steps, in order.</span>
          <a class="petcta-link" href={'/' + country.slug + '/' + petSpoke.slug}>{petSpoke.h1}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </span>
      </section>
    )}
    {country.spokes && country.spokes.filter(s => s.live !== false).length > 0 && (
      <section class="deeper">
        <p class="lab">Going deeper on {country.name}</p>
        <h2>The money questions people ask on the ground.</h2>
        <p class="sub">Short, focused answers to the specific things that catch first-timers out in {country.name}.</p>
        <ul class="deeper-list">
          {country.spokes.filter(s => s.live !== false).map(s => (
            <li>
              <a href={'/' + country.slug + '/' + s.slug}>
                <span class="deeper-h">{s.h1}</span>
                <span class="deeper-d">{s.lede}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
    <section class="guide-cta">
      <div class="gc-txt">
        <p class="gc-h">This is how {country.name} stands today.</p>
        <p class="gc-p">Money rules move. We can let you know for free if that changes.</p>
      </div>
      <a class="btn" href="#" data-open-signup>Keep me posted</a>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* "Going deeper" hub list: the country page's links to its spokes. Data-driven from
     the country's spokes array, so a new spoke appears here on its own. Reuses the
     shared tokens; only the list itself is styled here. */
  .deeper-list{list-style:none;margin:16px 0 0;padding:0;display:grid;gap:10px}
  .deeper-list a{display:block;background:var(--card);border:1px solid var(--line);border-radius:12px;padding:15px 17px;text-decoration:none;box-shadow:var(--shadow);transition:border-color .2s ease,box-shadow .2s ease,transform .2s ease}
  .deeper-list a:hover{border-color:#C2E0C8;transform:translateY(-1px)}
  .deeper-h{display:block;font-family:var(--serif);font-weight:500;font-size:17px;color:var(--ink);line-height:1.25;margin:0 0 4px}
  .deeper-d{display:block;font-size:14px;color:var(--muted);line-height:1.5}
  /* "Moving here with a pet?" relocation callout, shown only when the country has a
     live pets spoke. Distinct from the "Going deeper" list: a single prominent nudge
     for the subset of readers who are relocating rather than visiting. */
  .petcta{display:flex;gap:16px;align-items:flex-start;margin:26px 0 0;padding:18px 20px;border:1px solid var(--line);border-left:3px solid var(--teal);border-radius:var(--radius);background:var(--card);box-shadow:var(--shadow)}
  .petcta-ic{flex:none;width:40px;height:40px;border-radius:999px;background:var(--green-bg);color:var(--teal-deep);display:flex;align-items:center;justify-content:center;margin-top:2px}
  .petcta-tx{display:block}
  .petcta-h{display:block;margin:0 0 4px;font-family:var(--serif);font-weight:500;font-size:19px;color:var(--ink);line-height:1.2}
  .petcta-p{display:block;margin:0 0 10px;font-size:14.5px;color:var(--muted);line-height:1.55}
  .petcta-link{display:inline-flex;align-items:center;gap:6px;font-size:14.5px;font-weight:600;color:var(--teal-deep);text-decoration:none}
  .petcta-link:hover{text-decoration:underline}
  .petcta-link svg{transition:transform .15s ease}
  .petcta-link:hover svg{transform:translateX(3px)}
  @media (max-width:560px){.petcta{gap:12px;padding:16px}.petcta-h{font-size:17px}}
  @media (max-width:560px){
    .deeper-h{font-size:16px}
  }
</style>
