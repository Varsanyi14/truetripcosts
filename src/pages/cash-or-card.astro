---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { countries } from '../data/index.js';

// Read from each guide's calculator meter (cashPct), the same figure the on-guide
// bar uses, so this stays a single source and covers every guide. Nothing is
// re-typed, and it carries each guide's checked date by extension.
const live = countries.filter(c => c.live && !c.blocked && c.meter && typeof c.meter.cashPct === 'number');
const ranked = live
  .map(c => ({
    slug: c.slug,
    name: c.name,
    cashPct: c.meter.cashPct,
    heading: (c.meter && c.meter.heading) ? c.meter.heading : ('Day to day, ' + c.name + ' runs about ' + c.meter.cashPct + '% on cash.'),
  }))
  .sort((a, b) => a.cashPct - b.cashPct || a.name.localeCompare(b.name));
---
<Base
  title="Cash or card by country, for US travelers"
  description="Whether to carry cash or lean on cards, country by country: how card-friendly each place is day to day and how much cash to expect. For US travelers.">
  <Nav />
  <main class="wrap">

    <section class="fx-intro">
      <p class="fx-lab">Paying abroad</p>
      <h1>Cash or card, country by country.</h1>
      <p class="fx-lede">A quick read on how each country actually pays, from the near-cashless places where you barely touch a note to the ones that still run on cash. The bar shows the rough share of everyday spending that tends to be cash, so more teal means more cash. Cards usually climb higher in big cities, so treat this as a feel rather than a rule, and open the guide for the detail.</p>
    </section>

    {ranked.length > 0 && (
      <section class="fx-sec">
        <h2>From card-friendly to cash-first</h2>
        <p class="fx-note">Ordered by how much of everyday spending tends to be cash, lightest first. Each entry links to the full country guide.</p>
        <div class="fx-panel">
          {ranked.map(r => (
            <div class="fx-item">
              <div class="co-top">
                <a class="fx-country" href={'/' + r.slug}>{r.name}</a>
                <span class="co-pct">{r.cashPct}% cash</span>
              </div>
              <div class="co-bar" role="img" aria-label={r.cashPct + ' percent cash, ' + (100 - r.cashPct) + ' percent card'}>
                <div class="co-fill" style={'width:' + r.cashPct + '%'}></div>
              </div>
              <p class="co-note">{r.heading}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <p class="fx-keep">This is our own read from experience and each country's guide, not an official figure, and it is checked when we check the guide. For the fees behind a trip, see <a href="/tourist-taxes">tourist taxes and entry fees</a>, and every guide has the full money picture. More on how we work is on our <a href="/methodology">methodology page</a>.</p>

  </main>
  <Footer />

  <style>
    .fx-lab{font-size:12px;font-weight:600;color:var(--teal-deep);letter-spacing:.08em;text-transform:uppercase;margin:26px 0 10px}
    .fx-intro{max-width:680px}
    .fx-intro h1{margin:0 0 14px}
    .fx-lede{font-size:18px;color:#3B4A46;line-height:1.55;margin:0}
    .fx-sec{margin:36px 0}
    .fx-sec h2{font-family:var(--serif);font-weight:500;font-size:clamp(21px,3.2vw,27px);letter-spacing:-.01em;margin:0 0 6px}
    .fx-note{font-size:14.5px;color:var(--muted);margin:0 0 16px;line-height:1.5;max-width:680px}
    .fx-panel{border:1px solid var(--line);border-radius:var(--radius);background:var(--card);box-shadow:var(--shadow);overflow:hidden}
    .fx-item{padding:15px 18px;border-bottom:1px solid var(--line)}
    .fx-item:last-child{border-bottom:0}
    .fx-country{font-weight:600;font-size:15.5px;color:var(--teal-deep);text-decoration:none}
    .fx-country:hover{text-decoration:underline}
    .fx-keep{font-size:14px;color:var(--muted);line-height:1.55;border-top:1px solid var(--line);padding-top:18px;margin:30px 0 40px;max-width:680px}
    .fx-keep a{color:var(--teal-deep);font-weight:500;text-decoration:none}
    .fx-keep a:hover{text-decoration:underline}
    .co-top{display:flex;align-items:baseline;justify-content:space-between;gap:12px}
    .co-pct{font-size:13px;font-weight:600;color:var(--muted);white-space:nowrap}
    .co-bar{height:8px;border-radius:999px;background:#EDEBE4;overflow:hidden;margin-top:9px}
    .co-fill{height:100%;background:var(--teal);border-radius:999px}
    .co-note{font-size:14px;color:var(--muted);line-height:1.5;margin:9px 0 0}
    @media (max-width:560px){
      .fx-item{padding:14px 15px}
      .fx-lede{font-size:16.5px}
    }
  </style>
</Base>
