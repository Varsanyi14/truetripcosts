---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import USBadge from '../components/USBadge.astro';
import TipTiers from '../components/TipTiers.astro';
import TipGrid from '../components/TipGrid.astro';
import { tipping, usBaseline, tippingChecked } from '../data/tipping.js';

// Everything reads from tipping.js live. Nothing is re-typed, so a correction to
// the data corrects the ramp, the callouts and the grid on the next build.
const rows = tipping;
const TIERS = ['Not customary', 'Round up only', 'Small optional', 'Modest customary', 'Expected / standard'];
const tierCount = t => rows.filter(r => r.tier === t).length;

const noTip = rows.filter(r => r.tierRank === 0);
const usLevel = rows.filter(r => r.tierRank === 4);
const cashEssential = rows.filter(r => /essential/i.test(r.cashOrCard));
const chargeOnBill = rows.filter(r => r.serviceCharge !== 'rarely');

const regionsPresent = [...new Set(rows.map(r => r.region))].sort();
const chargeLevels = ['always', 'often', 'rarely'];
const chargeLabel = { always: 'Usually on the bill', often: 'Often on the bill', rarely: 'Rarely on the bill' };

// Regions a US traveler should budget nothing extra for, versus a real line item.
const lightRegions = ['Europe', 'Asia', 'Oceania'];
const heavyRegions = ['North America', 'Caribbean'];
const avgRank = list => list.length ? (list.reduce((a, r) => a + r.tierRank, 0) / list.length) : 0;
const lightAvg = avgRank(rows.filter(r => lightRegions.includes(r.region)));
const heavyAvg = avgRank(rows.filter(r => heavyRegions.includes(r.region)));

function niceDate(iso) {
  if (!iso) return '';
  const d = new Date(iso + 'T00:00:00');
  if (isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}
const checkedLabel = niceDate(tippingChecked);

const title = 'Tipping by country, compared to what US travelers do at home | True Trip Costs';
const description = 'How tipping works in ' + rows.length + ' countries, measured against the US habit of 15 to 20 percent. Custom, not law: what to leave, whether a service charge is already on the bill, and whether to use cash. Checked ' + checkedLabel + '.';
---

<Base title={title} description={description}>
  <Nav />
  <main class="wrap tipage">
    <p class="ctx"><USBadge /> <span class="stamp">Checked {checkedLabel}</span></p>
    <h1>Your tipping instinct is wrong almost everywhere</h1>

    <p class="tipage-lede">
      You already know what you leave at home. Here is how far off that is in {rows.length} countries.
    </p>

    <section class="tipage-ramp" aria-label="Where countries sit against the US habit">
      <TipTiers rows={rows} baseline={usBaseline} tiers={TIERS} id="ramp" />
    </section>

    <section class="bigstat" aria-label="The headline numbers">
      <div class="bs">
        <span class="bs-n">{noTip.length}</span>
        <span class="bs-l">expect nothing</span>
        <span class="bs-s">Leaving money is not the norm</span>
      </div>
      <div class="bs">
        <span class="bs-n">{chargeOnBill.length}</span>
        <span class="bs-l">put a charge on the bill</span>
        <span class="bs-s">Tipping again is the costly mistake</span>
      </div>
      <div class="bs is-us">
        <span class="bs-n">{usLevel.length}</span>
        <span class="bs-l">tip like the US</span>
        <span class="bs-s">Everywhere else expects less</span>
      </div>
    </section>

    <div class="tipage-honest">
      <p class="tipage-honest-h">This is custom, not law</p>
      <p>
        Tipping norms are social habits, not published rules. They vary by region, venue and season, and a
        busy tourist strip behaves differently from a neighborhood spot an hour away. That makes this a
        different kind of claim from our visa-fee and tourist-tax pages, where figures come from government
        sources. Sourcing quality varies by country, and every tile below shows how firm it is.
      </p>
    </div>

    <section class="tipage-budget" aria-label="What to budget">
      <h2>What to actually budget</h2>
      <div class="bg-rows">
        <div class="bg-row">
          <span class="bg-lab">Europe, Asia, Oceania</span>
          <span class="bg-track"><span class="bg-fill light" style={`width:${Math.round((lightAvg / 4) * 100)}%`}></span></span>
          <span class="bg-val">near zero</span>
        </div>
        <div class="bg-row">
          <span class="bg-lab">North America, Caribbean</span>
          <span class="bg-track"><span class="bg-fill heavy" style={`width:${Math.round((heavyAvg / 4) * 100)}%`}></span></span>
          <span class="bg-val">10 to 20%</span>
        </div>
      </div>
      <p class="bg-note">
        Across Europe and Japan the price you see is close to the price you pay. Across North America and
        the Caribbean, add a real line item to every meal and carry small bills.
      </p>
    </section>

    <section class="tipage-trap" aria-label="The service charge trap">
      <h2>The trap: a service charge is not always a tip</h2>
      <div class="trap">
        <div class="trap-step">
          <span class="trap-q">Charge on the bill?</span>
          <span class="trap-a trap-no">No</span>
          <span class="trap-r">Tip by the local norm</span>
        </div>
        <div class="trap-step">
          <span class="trap-q">Charge on the bill?</span>
          <span class="trap-a trap-yes">Yes</span>
          <span class="trap-r">Usually add nothing</span>
        </div>
        <div class="trap-step trap-alert">
          <span class="trap-q">But does it reach staff?</span>
          <span class="trap-a trap-warn">Not always</span>
          <span class="trap-r">Small cash to the server</span>
        </div>
      </div>
      <p class="trap-note">
        Taiwan treats the printed charge as general restaurant revenue by law, not a gratuity. In Egypt,
        Argentina, Georgia and Vietnam it commonly bypasses staff too. This inverts the US assumption, so
        a printed charge does not reliably mean staff are taken care of.
      </p>
    </section>

    <section class="tipage-detail" aria-labelledby="every-country">
      <h2 id="every-country">All {rows.length} countries</h2>
      <p class="tipage-sub">
        Darker means more expected. A dot means a service charge is usually on the bill. Tap any country for
        what to do and how firm our sourcing is.
      </p>

      <div class="tf" id="tip-filters">
        <div class="tf-group">
          <p class="tf-lab">Tier <span class="tf-count" id="tf-count">{rows.length} shown</span></p>
          <div class="tf-btns" role="group" aria-label="Filter by tipping tier">
            <button type="button" class="tf-chip is-active" data-tier-btn="__all" aria-pressed="true">All</button>
            {TIERS.map(t => (
              <button type="button" class="tf-chip" data-tier-btn={t} aria-pressed="false">{t} <span class="tf-n">{tierCount(t)}</span></button>
            ))}
          </div>
        </div>
        <div class="tf-group">
          <p class="tf-lab">Service charge</p>
          <div class="tf-btns" role="group" aria-label="Filter by service charge">
            <button type="button" class="tf-chip is-active" data-charge-btn="__all" aria-pressed="true">All</button>
            {chargeLevels.map(c => (
              <button type="button" class="tf-chip" data-charge-btn={c} aria-pressed="false">{chargeLabel[c]}</button>
            ))}
          </div>
        </div>
        <div class="tf-group">
          <p class="tf-lab">Region</p>
          <div class="tf-btns" role="group" aria-label="Filter by region">
            <button type="button" class="tf-chip is-active" data-region-btn="__all" aria-pressed="true">All</button>
            {regionsPresent.map(r => (
              <button type="button" class="tf-chip" data-region-btn={r} aria-pressed="false">{r}</button>
            ))}
          </div>
        </div>
      </div>

      <TipGrid rows={rows} id="grid" />
      <p class="tl-empty" id="tl-empty" hidden>Nothing matches those filters together. Reset one to see countries again.</p>
    </section>

    <p class="tipage-foot">
      Checked {checkedLabel} by the True Trip Costs desk. Tipping norms move faster than most travel facts:
      card terminals keep nudging suggested percentages upward, Turkey banned mandatory service charges in
      2026, and a 2025 Indian court ruling confirmed service charges there are voluntary. Where sources
      disagreed we lowered the confidence rather than picking a number that looked tidy.
    </p>
  </main>
  <Footer />

  <style>
    .tipage{max-width:900px}
    .tipage h1{margin-bottom:10px}
    .tipage-lede{font-size:18px;color:#3B4A46;line-height:1.5;max-width:620px;margin:0 0 22px}
    .tipage-ramp{margin:0 0 22px}

    .bigstat{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin:0 0 26px}
    .bs{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:14px 16px;display:flex;flex-direction:column;gap:2px}
    .bs.is-us{border-color:var(--amber);background:var(--amber-bg)}
    .bs-n{font-family:var(--serif);font-size:34px;line-height:1;color:var(--ink)}
    .bs-l{font-size:14px;font-weight:700;color:var(--ink)}
    .bs-s{font-size:12.5px;color:var(--muted);line-height:1.4}

    .tipage-honest{background:var(--card);border:1px solid var(--line);border-left:3px solid var(--teal);border-radius:12px;padding:14px 18px;margin:0 0 30px;max-width:720px;box-shadow:var(--shadow)}
    .tipage-honest-h{font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--teal-deep);margin:0 0 6px}
    .tipage-honest p{font-size:14px;color:var(--muted);line-height:1.55;margin:0}

    .tipage h2{font-family:var(--serif);font-weight:500;font-size:clamp(20px,3.2vw,27px);letter-spacing:-.01em;margin:0 0 12px}

    .tipage-budget{margin:0 0 34px}
    .bg-rows{display:flex;flex-direction:column;gap:9px}
    .bg-row{display:grid;grid-template-columns:minmax(120px,190px) 1fr auto;align-items:center;gap:11px}
    .bg-lab{font-size:13.5px;font-weight:600;color:var(--ink)}
    .bg-track{height:15px;background:rgba(10,86,68,.09);border-radius:5px;overflow:hidden}
    .bg-fill{display:block;height:100%;border-radius:5px}
    .bg-fill.light{background:rgba(10,86,68,.42)}
    .bg-fill.heavy{background:var(--amber)}
    .bg-val{font-family:var(--serif);font-size:14.5px;color:var(--ink);white-space:nowrap}
    .bg-note{font-size:13.5px;color:var(--muted);line-height:1.55;margin:11px 0 0;max-width:660px}

    .tipage-trap{margin:0 0 36px}
    .trap{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:10px}
    .trap-step{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:13px 15px;display:flex;flex-direction:column;gap:5px}
    .trap-step.trap-alert{border-color:var(--amber);background:var(--amber-bg)}
    .trap-q{font-size:12.5px;color:var(--muted)}
    .trap-a{font-size:13px;font-weight:700;align-self:flex-start;border-radius:999px;padding:2px 10px}
    .trap-no{background:rgba(10,86,68,.12);color:var(--teal-deep)}
    .trap-yes{background:rgba(10,86,68,.12);color:var(--teal-deep)}
    .trap-warn{background:var(--amber);color:#fff}
    .trap-r{font-size:14.5px;font-weight:700;color:var(--ink);line-height:1.35}
    .trap-note{font-size:13.5px;color:var(--muted);line-height:1.55;margin:12px 0 0;max-width:680px}

    .tipage-sub{font-size:14px;color:var(--muted);margin:0 0 16px;max-width:640px;line-height:1.5}

    .tf{display:flex;flex-direction:column;gap:12px;margin:0 0 16px}
    .tf-lab{font-size:12.5px;font-weight:700;color:var(--ink);margin:0 0 6px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .tf-count{font-weight:600;color:var(--muted);font-size:12px}
    .tf-btns{display:flex;flex-wrap:wrap;gap:6px}
    .tf-chip{font:inherit;font-size:12.5px;font-weight:600;color:var(--muted);background:var(--card);border:1px solid var(--line);border-radius:999px;padding:6px 12px;cursor:pointer;transition:background .16s ease,border-color .16s ease,color .16s ease}
    .tf-chip:hover{border-color:var(--amber);color:var(--amber)}
    .tf-chip.is-active{background:var(--amber);border-color:var(--amber);color:#fff}
    .tf-n{opacity:.75;font-variant-numeric:tabular-nums}

    .tl-empty{font-size:14.5px;color:var(--muted);background:var(--card);border:1px solid var(--line);border-radius:12px;padding:16px;margin:14px 0 0}
    .tipage-foot{font-size:13.5px;color:var(--muted);line-height:1.55;margin:34px 0 8px;max-width:700px}

    @media (max-width:560px){
      .tipage-lede{font-size:16.5px}
      .bigstat{grid-template-columns:1fr}
      .bs{flex-direction:row;align-items:baseline;flex-wrap:wrap;gap:8px}
      .bs-n{font-size:28px}
      .bs-s{flex-basis:100%}
      .bg-row{grid-template-columns:1fr;gap:4px}
      .bg-val{justify-self:start}
    }
  </style>

  <script is:inline>
    (function () {
      var grid = document.getElementById('grid-grid');
      if (!grid) return;
      var cells = Array.prototype.slice.call(grid.querySelectorAll('.tg-cell'));
      var panel = document.getElementById('grid-panel');
      var countEl = document.getElementById('tf-count');
      var emptyEl = document.getElementById('tl-empty');
      var total = cells.length;
      var sel = { tier: '__all', charge: '__all', region: '__all' };
      var openCell = null;

      function apply() {
        var shown = 0;
        cells.forEach(function (c) {
          var ok = (sel.tier === '__all' || c.getAttribute('data-tier') === sel.tier)
            && (sel.charge === '__all' || c.getAttribute('data-charge') === sel.charge)
            && (sel.region === '__all' || c.getAttribute('data-region') === sel.region);
          c.classList.toggle('is-hidden', !ok);
          if (ok) shown++;
        });
        if (countEl) countEl.textContent = shown + ' shown';
        if (emptyEl) emptyEl.hidden = shown !== 0;
        // A hidden country should not leave its detail panel open.
        if (openCell && openCell.classList.contains('is-hidden')) closePanel();
      }

      function closePanel() {
        if (panel) { panel.hidden = true; panel.innerHTML = ''; }
        if (openCell) {
          openCell.classList.remove('is-open');
          var b = openCell.querySelector('.tg-btn');
          if (b) b.setAttribute('aria-expanded', 'false');
        }
        openCell = null;
      }

      function openPanel(cell) {
        var raw = cell.querySelector('.tg-data');
        if (!raw || !panel) return;
        var d;
        try { d = JSON.parse(raw.textContent); } catch (e) { return; }
        closePanel();
        openCell = cell;
        cell.classList.add('is-open');
        var btn = cell.querySelector('.tg-btn');
        if (btn) btn.setAttribute('aria-expanded', 'true');

        var html = '<div class="tg-panel-h"><span class="tg-panel-c">' + d.country + '</span>'
          + '<span class="tg-panel-t">' + d.tier + '</span>'
          + '<button type="button" class="tg-close">Close</button></div>'
          + '<p class="tg-remember">' + d.remember + '</p>'
          + '<dl class="tg-facts">'
          + '<div><dt>Restaurant</dt><dd>' + d.restaurant + '</dd></div>'
          + '<div><dt>Service charge</dt><dd>' + d.charge + '</dd></div>'
          + '<div><dt>On top of it</dt><dd>' + d.onTop + '</dd></div>'
          + '<div><dt>Cash or card</dt><dd>' + d.cash + '</dd></div>'
          + '<div><dt>Sourcing</dt><dd>' + d.sourcing + '</dd></div>'
          + '</dl>';
        if (d.hasGuide) html += '<a class="tg-guide" href="/' + d.slug + '">Full ' + d.country + ' money guide</a>';
        panel.innerHTML = html;
        panel.hidden = false;
        var close = panel.querySelector('.tg-close');
        if (close) close.addEventListener('click', closePanel);
      }

      grid.addEventListener('click', function (e) {
        var btn = e.target.closest ? e.target.closest('.tg-btn') : null;
        if (!btn) return;
        var cell = btn.closest('.tg-cell');
        if (!cell) return;
        if (cell === openCell) { closePanel(); return; }
        openPanel(cell);
      });

      function wire(attr, key) {
        var btns = document.querySelectorAll('[' + attr + ']');
        btns.forEach(function (btn) {
          btn.addEventListener('click', function () {
            sel[key] = btn.getAttribute(attr);
            btns.forEach(function (x) {
              var on = x === btn;
              x.classList.toggle('is-active', on);
              x.setAttribute('aria-pressed', on ? 'true' : 'false');
            });
            apply();
          });
        });
      }
      wire('data-tier-btn', 'tier');
      wire('data-charge-btn', 'charge');
      wire('data-region-btn', 'region');
    })();
  </script>
</Base>
