---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import USBadge from '../components/USBadge.astro';
import { countries } from '../data/index.js';
import fs from 'node:fs';
const live = countries.filter(c => c.live);
const soon = countries.filter(c => !c.live);
// Flags auto-detect: drop public/flags/<slug>.svg and it shows on the next build.
// A missing flag falls back to the globe, so nothing ever renders broken.
const flagDir = process.cwd() + '/public/flags/';
const flagSrc = (slug) => fs.existsSync(flagDir + slug + '.svg') ? `/flags/${slug}.svg` : '/flags/world.svg';
// Hero illustration: save your image at public/hero/landing.png and it turns on automatically
// on the next build. No image there means the text-only hero stays. Nothing to toggle by hand.
const heroImage = fs.existsSync(process.cwd() + '/public/hero/landing.jpg') ? '/hero/landing.jpg' : (fs.existsSync(process.cwd() + '/public/hero/landing.png') ? '/hero/landing.png' : null);
// Region label and one-line rail blurb. NEW countries set `region` and `hook`
// in their own data file (src/data/<slug>.js); these maps are only a fallback for
// the original nine, so you never edit this file when adding a country.
const regionTag = {
  vietnam: 'Asia', japan: 'Asia', thailand: 'Asia',
  mexico: 'Americas',
  italy: 'Europe', france: 'Europe', spain: 'Europe', portugal: 'Europe', 'united-kingdom': 'Europe'
};
const hooks = {
  vietnam: 'A cash country at heart. Cards work in cities, far less beyond them.',
  japan: 'More card-friendly than its reputation, but keep cash for small spots.',
  mexico: 'Cards taken widely at resorts. Watch the peso conversion trick at the till.',
  thailand: 'Cards in malls and hotels, cash for street food and markets.',
  italy: 'Cards almost everywhere, plus a nightly tourist tax to plan for.',
  france: 'Tap and pay is the norm, with a small nightly city tax on top.',
  spain: 'Cards taken widely, with a per-night tourist tax in many regions.',
  portugal: 'Easy on cards, with a small municipal tax in the bigger cities.',
  'united-kingdom': 'A tap-to-pay country. No card-fee worries, just the exchange rate.'
};
const tick = '<svg class="tick" viewBox="0 0 24 24" fill="none" stroke="#15803D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
---
<Base title="True Trip Costs: cards, cash and fees, the money side of travel" description="Independent money guides for US travelers, country by country: cash or card, the fees to dodge, tourist taxes and tipping. The money side, checked and dated.">
  <Nav />
  <main class="wrap">
    <section class={"home-hero" + (heroImage ? " has-hero-img" : "")}>
      {heroImage && <div class="hh-media" style={`background-image:url('${heroImage}')`} aria-hidden="true"></div>}
      <div class="hh-body">
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:9px;margin:0 0 16px"><USBadge /><span class="tagpill" style="margin:0">The fees nobody quotes you</span></div>
        <h1>The money side of your trip, sorted.</h1>
        <p class="lede">Plain-language money guides for travelers leaving the US: what to pay with, how much cash to carry, and the fees to dodge. The money side of a trip, not a flights-and-hotels budget.</p>
        <div class="hero-search">
          <div class="cfilter cfilter-hero">
            <svg class="cfilter-ic" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="text" id="country-filter-hero" class="cfilter-in" placeholder="Know where you are going? Type a country, like Japan" aria-label="Search country guides" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="hero-ta-list" aria-autocomplete="list" />
          </div>
          <div class="hero-ta" id="hero-ta" hidden>
            <div class="hero-ta-list" id="hero-ta-list" role="listbox" aria-label="Matching country guides">
              {live.map(c => (
                <a class="hero-ta-item" href={'/' + c.slug} data-name={[c.name, ...(c.aliases || [])].join(' ').toLowerCase()}>
                  <img class="hero-ta-flag" src={flagSrc(c.slug)} alt="" width="22" height="16" loading="lazy" />
                  <span class="hero-ta-name">{c.name}</span>
                  <span class="hero-ta-go" aria-hidden="true">&#8594;</span>
                </a>
              ))}
            </div>
            <p class="hero-ta-none" id="hero-ta-none" hidden>No guide for that one yet. <a href="#" data-open-signup>Get a heads-up as we add countries</a>.</p>
          </div>
        </div>
        <div class="hpcta">
          <a class="ghost" href="#why">Why this exists &#8594;</a>
        </div>
      </div>
    </section>

    <section class="qa" aria-label="Quick answers">
      <p class="qa-lab">Quick answers</p>
      <div class="qa-grid">
        <a class="qa-card" href="/tourist-taxes">
          <span class="qa-t">Tourist taxes and entry fees</span>
          <span class="qa-d">What each country charges to visit or stay, dated and linked to the official source.</span>
          <span class="qa-go" aria-hidden="true">&#8594;</span>
        </a>
        <a class="qa-card" href="/cash-or-card">
          <span class="qa-t">Cash or card by country</span>
          <span class="qa-d">How card-friendly each place is, and how much cash to carry.</span>
          <span class="qa-go" aria-hidden="true">&#8594;</span>
        </a>
      </div>
    </section>

    <section class="dsc" aria-label="Start from your question">
      <p class="dsc-lab">Arriving with a worry, not a country?</p>
      <p class="dsc-intro">Start from the question on your mind.</p>
      <div class="dsc-grid">
        <a class="dsc-chip" href="/cash-or-card">
          <span class="dsc-q">Will my card work abroad?</span>
          <span class="dsc-go" aria-hidden="true">&#8594;</span>
        </a>
        <a class="dsc-chip" href="/cash-or-card">
          <span class="dsc-q">How much cash should I carry?</span>
          <span class="dsc-go" aria-hidden="true">&#8594;</span>
        </a>
        <a class="dsc-chip" href="/passports-and-visas">
          <span class="dsc-q">Do I need a visa?</span>
          <span class="dsc-go" aria-hidden="true">&#8594;</span>
        </a>
        <a class="dsc-chip" href="/tourist-taxes">
          <span class="dsc-q">What will tourist taxes cost me?</span>
          <span class="dsc-go" aria-hidden="true">&#8594;</span>
        </a>
        <a class="dsc-chip" href="/taxis-and-ride-hailing">
          <span class="dsc-q">Will the taxi overcharge me?</span>
          <span class="dsc-go" aria-hidden="true">&#8594;</span>
        </a>
      </div>
    </section>

    <section class="rail-wrap" aria-label="Browse country guides">
      <p class="rail-lab">Browse the guides</p>
      <div class="rail">
        {live.map(c => (
          <a class="rcard" href={'/' + c.slug}>
            <span class="rtop">
              <span class="rflag" aria-hidden="true"><img src={flagSrc(c.slug)} alt="" width="26" height="20" loading="lazy" /></span>
              <span class="rtag">{c.region || regionTag[c.slug] || ''}</span>
              {(c.spokes || []).some(s => s.topic === 'pets' && s.live !== false) && (
                <span class="rpet"><svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><ellipse cx="6.4" cy="10.2" rx="1.9" ry="2.5"/><ellipse cx="10.1" cy="7.5" rx="1.9" ry="2.6"/><ellipse cx="13.9" cy="7.5" rx="1.9" ry="2.6"/><ellipse cx="17.6" cy="10.2" rx="1.9" ry="2.5"/><path d="M12 11.3c-2.8 0-5.1 2-5.1 4.4 0 1.9 1.7 3 3.5 2.6.6-.13 1.1-.19 1.6-.19s1 .06 1.6.19c1.8.4 3.5-.7 3.5-2.6 0-2.4-2.3-4.4-5.1-4.4z"/></svg>Pets</span>
              )}
            </span>
            <span class="rname">{c.name}</span>
            <span class="rhook">{c.hook || hooks[c.slug] || ''}</span>
            <span class="rgo">Guide <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
          </a>
        ))}
      </div>
    </section>

    <section class="why" id="why">
      <p class="lab">The money question</p>
      <h2>Booking the trip is the easy part. The money side is a mess.</h2>
      <p class="lead">You search how much cash to bring and get ten-year-old blog posts, contradictory forum threads, and pages quietly written to sell you one credit card. So you guess. Then comes the surprise card surcharge, the bad airport exchange counter, or a tourist tax nobody mentioned. We turn that into one calm, current answer for each country, in about five minutes.</p>
      <div class="qrow">
        <div class="qcard"><h3>Will my card work?</h3><p>We look at the cards you already carry, not a generic one, against how each country actually takes payment day to day.</p></div>
        <div class="qcard"><h3>Do I need cash?</h3><p>A straight read on how much to carry, and the places where the honest answer is almost none.</p></div>
        <div class="qcard"><h3>What will it really cost?</h3><p>The conversion tricks, ATM fees and tourist taxes that creep in, named up front so nothing ambushes you later.</p></div>
      </div>
    </section>

    <section class="honest">
      <p class="lab">How we are different</p>
      <h2>We would rather tell you to do nothing.</h2>
      <div class="hrow">
        <div class="hitem"><p class="hk"><Fragment set:html={tick} />Sometimes the answer is, you are fine</p><p>If the card already in your pocket works with no fee, we say so plainly, and there is nothing for you to buy.</p></div>
        <div class="hitem"><p class="hk"><Fragment set:html={tick} />Labeled, every single time</p><p>Links that earn us a commission are marked as such, and the ones that do not are marked too, so you always know which is which.</p></div>
        <div class="hitem"><p class="hk"><Fragment set:html={tick} />Checked, dated, kept current</p><p>We do not sell hotel rooms, and every guide shows the date we last checked it. Money rules shift, so staying current is the whole point.</p></div>
      </div>
    </section>

    <section class="csec" id="guides">
      <p class="lab">Money guides</p>
      <h2>Pick where you are going.</h2>
      <p class="sub">Each guide is a five-minute money briefing for that country, written for travelers leaving the US. Before you book, see <a href="/passports-and-visas"><b>what documents you need to get in</b></a>.</p>
      <div class="cfilter">
        <svg class="cfilter-ic" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" id="country-filter" class="cfilter-in" placeholder="Type a country, like Japan or Costa Rica" aria-label="Filter country guides by name" autocomplete="off" />
      </div>
      <p class="cfilter-none" id="country-filter-none" hidden>No match yet. Try another spelling, or <a href="#" data-open-signup><b>let us keep you posted as we add countries</b></a>.</p>
      <div class="country-grid" id="country-grid">
        {live.map(c => (
          <a class="ccard" href={'/' + c.slug} data-name={[c.name, ...(c.aliases || [])].join(' ').toLowerCase()}>
            <span class="cthumb">
              <img src={(c.hero && c.hero.img) || ('/' + c.slug + '-hero.jpg')} alt={'Money guide for ' + c.name} loading="lazy" decoding="async" width="400" height="300" />
              <span class="cflag" aria-hidden="true"><img src={flagSrc(c.slug)} alt="" width="24" height="18" loading="lazy" /></span>
              {(c.spokes || []).some(s => s.topic === 'pets' && s.live !== false) && (
                <span class="cpet"><svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><ellipse cx="6.4" cy="10.2" rx="1.9" ry="2.5"/><ellipse cx="10.1" cy="7.5" rx="1.9" ry="2.6"/><ellipse cx="13.9" cy="7.5" rx="1.9" ry="2.6"/><ellipse cx="17.6" cy="10.2" rx="1.9" ry="2.5"/><path d="M12 11.3c-2.8 0-5.1 2-5.1 4.4 0 1.9 1.7 3 3.5 2.6.6-.13 1.1-.19 1.6-.19s1 .06 1.6.19c1.8.4 3.5-.7 3.5-2.6 0-2.4-2.3-4.4-5.1-4.4z"/></svg>Pets</span>
              )}
            </span>
            <span class="cbody">
              <span class="cname">{c.name}</span>
              <span class="chook">{c.meter ? c.meter.heading : ''}</span>
              <span class="cgo">Open guide &#8594;</span>
            </span>
          </a>
        ))}
        {soon.map(c => (
          <span class="ccard soon" data-name={[c.name, ...(c.aliases || [])].join(' ').toLowerCase()}>
            <span class="cthumb"><span class="cflag" aria-hidden="true"><img src={flagSrc(c.slug)} alt="" width="24" height="18" loading="lazy" /></span></span>
            <span class="cbody"><span class="cname">{c.name}</span><span class="cgo">Coming soon</span></span>
          </span>
        ))}
      </div>
      <p class="sub" style="margin-top:22px">Heading somewhere, or just travel a lot? <a href="#" data-open-signup><b>Get a free heads-up when the money side changes</b></a>.</p>
    </section>
  </main>
  <Footer />

  <style>
    .cfilter{display:flex;align-items:center;gap:10px;max-width:440px;margin:0 0 26px;padding:11px 15px;border:1px solid var(--line,#E5E3DB);border-radius:12px;background:var(--card,#FFFFFF);transition:border-color .15s ease,box-shadow .15s ease}
    .cfilter:focus-within{border-color:var(--ink,#16302C);box-shadow:0 0 0 3px rgba(14,122,95,.12)}
    .cfilter-ic{color:var(--muted,#6F6E66);flex:none;opacity:.6}
    .cfilter-in{flex:1;border:0;outline:0;background:transparent;font:inherit;font-size:1rem;color:var(--ink,#16302C)}
    .cfilter-in::placeholder{color:var(--muted,#6F6E66);opacity:.8}
    .cfilter-none{margin:0 0 22px;color:var(--muted,#6F6E66)}
    .ccard.is-hidden{display:none}
    .cpet{position:absolute;top:10px;right:10px;display:inline-flex;align-items:center;gap:4px;background:rgba(245,244,239,.94);color:var(--teal-deep,#0A5644);border-radius:999px;padding:4px 9px 4px 7px;font-size:11px;font-weight:700;letter-spacing:.02em;line-height:1;box-shadow:0 1px 3px rgba(22,48,44,.2)}
    .cpet svg{flex:none}
    .qa{margin:14px 0 6px}
    .qa-lab{font-size:12px;font-weight:600;color:var(--teal-deep,#0A5644);letter-spacing:.08em;text-transform:uppercase;margin:0 0 12px}
    .qa-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .qa-card{position:relative;display:block;padding:16px 18px;border:1px solid var(--line,#E5E3DB);border-radius:var(--radius,14px);background:var(--card,#FFFFFF);box-shadow:var(--shadow);text-decoration:none}
    .qa-card:hover{border-color:var(--teal,#0E7A5F)}
    .qa-t{display:block;font-weight:600;font-size:15.5px;color:var(--ink,#16302C);margin:0 0 4px}
    .qa-d{display:block;font-size:14px;color:var(--muted,#6F6E66);line-height:1.45;max-width:36ch}
    .qa-go{position:absolute;top:16px;right:16px;color:var(--teal-deep,#0A5644);font-weight:700}
    .qa-card:hover .qa-t{color:var(--teal-deep,#0A5644)}
    @media (max-width:560px){ .qa-grid{grid-template-columns:1fr} }
    .dsc{margin:28px 0 10px}
    .dsc-lab{font-size:12px;font-weight:600;color:var(--teal-deep,#0A5644);letter-spacing:.08em;text-transform:uppercase;margin:0 0 4px}
    .dsc-intro{font-size:14px;color:var(--muted,#6F6E66);margin:0 0 12px}
    .dsc-grid{display:flex;flex-wrap:wrap;gap:10px}
    .dsc-chip{display:inline-flex;align-items:center;gap:10px;padding:10px 15px;border:1px solid var(--line,#E5E3DB);border-radius:999px;background:var(--card,#FFFFFF);box-shadow:var(--shadow);text-decoration:none}
    .dsc-chip:hover{border-color:var(--teal,#0E7A5F)}
    .dsc-q{font-weight:600;font-size:14.5px;color:var(--ink,#16302C)}
    .dsc-go{color:var(--teal-deep,#0A5644);font-weight:700}
    .dsc-chip:hover .dsc-q{color:var(--teal-deep,#0A5644)}
    @media (max-width:560px){ .dsc-grid{flex-direction:column} .dsc-chip{justify-content:space-between} }
    /* Hero typeahead: a small list of matching guides under the hero search box. */
    .hero-search{position:relative;max-width:420px;margin:0 0 24px}
    .hero-search .cfilter{margin-bottom:0}
    .hero-ta{position:absolute;left:0;right:0;top:calc(100% + 6px);z-index:30;background:var(--card,#FFFFFF);border:1px solid var(--line,#E5E3DB);border-radius:12px;box-shadow:0 14px 34px rgba(16,48,44,.16);max-height:328px;overflow-y:auto;padding:6px}
    .hero-ta-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:var(--ink,#16302C)}
    .hero-ta-item:hover,.hero-ta-item.is-active{background:var(--green-bg,#E7F3E9)}
    .hero-ta-item.is-hidden{display:none}
    .hero-ta-flag{flex:none;border-radius:2px;box-shadow:0 0 0 1px rgba(22,48,44,.08)}
    .hero-ta-name{flex:1;font-size:15px;font-weight:500}
    .hero-ta-go{color:var(--teal-deep,#0A5644);font-weight:700}
    .hero-ta-none{margin:0;padding:12px 14px;font-size:14px;color:var(--muted,#6F6E66)}
    .hero-ta-none a{color:var(--teal-deep,#0A5644);font-weight:600}
    @media (max-width:640px){ .hero-search{max-width:none} }
    /* The desktop hero clips to rounded corners with overflow:hidden, which would
       cut off the dropdown. Let the section overflow, and round the image itself
       instead so it still sits neatly inside the corners. */
    @media (min-width:721px){
      .home-hero.has-hero-img{overflow:visible}
      .home-hero.has-hero-img .hh-media{border-radius:18px;overflow:hidden}
    }
  </style>

  <script>
    // Two independent pieces, each in its own scope:
    //   1) the lower search box filters the country grid in place (unchanged),
    //   2) the hero search box is a typeahead that lists matches and opens a guide.
    // Each has an early return and keeps its helpers at the top level, so a bundler
    // can never let a renamed variable from one collide with the other.

    (function () {
      function norm(s) {
        return (s || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      }
      var lower = document.getElementById('country-filter');
      var grid = document.getElementById('country-grid');
      if (!lower || !grid) return;
      var none = document.getElementById('country-filter-none');
      var cards = grid.querySelectorAll('.ccard');
      lower.addEventListener('input', function () {
        var q = norm(lower.value.trim());
        var shown = 0;
        for (var i = 0; i < cards.length; i++) {
          var hit = q === '' || norm(cards[i].getAttribute('data-name')).indexOf(q) !== -1;
          cards[i].classList.toggle('is-hidden', !hit);
          if (hit) shown++;
        }
        if (none) none.hidden = shown !== 0;
      });
    })();

    (function () {
      function norm(s) {
        return (s || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      }
      var hero = document.getElementById('country-filter-hero');
      var panel = document.getElementById('hero-ta');
      var listEl = document.getElementById('hero-ta-list');
      if (!hero || !panel || !listEl) return;
      var noneEl = document.getElementById('hero-ta-none');
      var items = Array.prototype.slice.call(listEl.querySelectorAll('.hero-ta-item'));
      var active = -1;

      function visible() {
        return items.filter(function (it) { return !it.classList.contains('is-hidden'); });
      }
      function clearActive() {
        for (var i = 0; i < items.length; i++) items[i].classList.remove('is-active');
        active = -1;
      }
      function openPanel() { panel.hidden = false; hero.setAttribute('aria-expanded', 'true'); }
      function closePanel() { panel.hidden = true; hero.setAttribute('aria-expanded', 'false'); clearActive(); }

      function run() {
        var q = norm(hero.value.trim());
        if (q === '') { closePanel(); return; }
        var shown = 0;
        for (var i = 0; i < items.length; i++) {
          var hit = norm(items[i].getAttribute('data-name')).indexOf(q) !== -1;
          items[i].classList.toggle('is-hidden', !hit);
          if (hit) shown++;
        }
        clearActive();
        if (noneEl) noneEl.hidden = shown !== 0;
        openPanel();
      }

      function setActive(next) {
        var vis = visible();
        if (!vis.length) return;
        clearActive();
        if (next < 0) next = vis.length - 1;
        if (next >= vis.length) next = 0;
        vis[next].classList.add('is-active');
        active = next;
        if (typeof vis[next].scrollIntoView === 'function') {
          try { vis[next].scrollIntoView({ block: 'nearest' }); } catch (e) {}
        }
      }

      hero.addEventListener('input', run);
      hero.addEventListener('focus', function () { if (hero.value.trim() !== '') run(); });
      hero.addEventListener('keydown', function (e) {
        if (panel.hidden) return;
        if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
        else if (e.key === 'Enter') {
          var vis = visible();
          var target = (active >= 0 && vis[active]) ? vis[active] : vis[0];
          if (target) { e.preventDefault(); window.location.href = target.getAttribute('href'); }
        } else if (e.key === 'Escape') { closePanel(); }
      });

      for (var j = 0; j < items.length; j++) {
        (function (it) {
          it.addEventListener('mousemove', function () {
            clearActive();
            it.classList.add('is-active');
            active = visible().indexOf(it);
          });
        })(items[j]);
      }

      document.addEventListener('click', function (e) {
        var wrap = hero.closest ? hero.closest('.hero-search') : null;
        if (wrap && !wrap.contains(e.target)) closePanel();
      });
    })();
  </script>
</Base>
