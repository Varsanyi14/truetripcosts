---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import USBadge from '../components/USBadge.astro';
import { countries } from '../data/index.js';

// Taxi and ride-hailing spokes, gathered from every guide by topic. A country
// appears here only when it has a written-up taxi wrinkle worth walking through:
// a meter trick, the right app to install, or the airport-rank trap. Same single
// source as everything else; adding a topic:"taxis" spoke to any guide surfaces
// it here automatically, mirroring how cash-or-card gathers the cash spokes.
const taxiSpokes = countries
  .filter(c => c.live)
  .flatMap(c => (c.spokes || [])
    .filter(s => s.topic === 'taxis' && s.live !== false)
    .map(s => ({ h1: s.h1, lede: s.lede, spokeSlug: s.slug, country: c.name, countrySlug: c.slug })))
  .sort((a, b) => a.country.localeCompare(b.country));
---
<Base
  title="Taxis and ride-hailing by country, for US travelers"
  description="Which taxi app to install, how the meter and airport scams actually work, and the official cheap way from the airport into town, country by country. For US travelers.">
  <Nav />
  <main class="wrap">

    <section class="fx-intro">
      <p class="fx-lab">Getting around</p>
      <div style="margin:2px 0 12px"><USBadge /></div>
      <h1>Taxis and ride-hailing, country by country.</h1>
      <p class="fx-lede">Written for travelers leaving the US, this is the calm version of a question every trip raises: is the taxi a rip-off, which app should I install, and how do I get from the airport into town without overpaying. The answer changes by country, so we write one up wherever the meter, the app, or the airport rank has a specific trick worth knowing. We name the official or cheapest safe route first, and we take nothing from any taxi or app company.</p>
    </section>

    {taxiSpokes.length > 0 && (
      <section class="fx-sec">
        <h2>Taxi questions, country by country</h2>
        <p class="fx-note">Where a place has a specific taxi or ride-hailing wrinkle worth walking through, we have written it up. Each one lives in that country's guide.</p>
        <div class="fx-panel">
          {taxiSpokes.map(s => (
            <a class="co-spoke" href={'/' + s.countrySlug + '/' + s.spokeSlug}>
              <span class="co-spoke-h">{s.h1}</span>
              <span class="co-spoke-d">{s.lede}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <p class="fx-keep">These are our own reads from experience and each country's guide, not official figures, and they are checked when we check the guide. Ride-hailing apps have no travel booking to sell, so we earn nothing here. For the fees behind a trip, see <a href="/tourist-taxes">tourist taxes and entry fees</a>, and for how each place pays, see <a href="/cash-or-card">cash or card</a>. More on how we work is on our <a href="/methodology">methodology page</a>.</p>

  </main>
  <Footer />

  <style>
    .fx-lab{font-size:12px;font-weight:600;color:var(--teal-deep);letter-spacing:.08em;text-transform:uppercase;margin:26px 0 10px}
    .fx-intro{max-width:680px}
    .fx-intro h1{margin:0 0 14px}
    .fx-lede{font-size:18px;color:#3B4A46;line-height:1.55;margin:0}
    .fx-sec{margin:36px 0}
    .fx-sec h2{font-family:var(--serif);font-weight:500;font-size:clamp(21px,3.2vw,27px);letter-spacing:-.01em;margin:0 0 6px}
    .fx-note{font-size:14.5px;color:var(--muted);margin:0 0 16px;line-height:1.5;max-width:680px}
    .fx-panel{border:1px solid var(--line);border-radius:var(--radius);background:var(--card);box-shadow:var(--shadow);overflow:hidden}
    .fx-keep{font-size:14px;color:var(--muted);line-height:1.55;border-top:1px solid var(--line);padding-top:18px;margin:30px 0 40px;max-width:680px}
    .fx-keep a{color:var(--teal-deep);font-weight:500;text-decoration:none}
    .fx-keep a:hover{text-decoration:underline}
    .co-spoke{display:block;padding:15px 18px;border-bottom:1px solid var(--line);text-decoration:none;transition:background-color .15s ease}
    .co-spoke:last-child{border-bottom:0}
    .co-spoke:hover{background:var(--paper)}
    .co-spoke-h{display:block;font-family:var(--serif);font-weight:500;font-size:16.5px;color:var(--teal-deep);line-height:1.3;margin:0 0 3px}
    .co-spoke:hover .co-spoke-h{text-decoration:underline}
    .co-spoke-d{display:block;font-size:14px;color:var(--muted);line-height:1.5}
    @media (max-width:560px){
      .fx-lede{font-size:16.5px}
    }
  </style>
</Base>
