---
import Symbol from './Symbol.astro';
import { affiliate, esimLink } from '../data/links.js';
import { fallbackFxPct, shortlistFor, cardsChecked } from '../data/cards.js';
import { countries } from '../data/index.js';
const { country: c } = Astro.props;
const jumpTargets = countries.filter(x => x.live && !x.blocked && x.slug !== c.slug).sort((a, b) => a.name.localeCompare(b.name));
const esim = esimLink(c.slug);
// Everything the honest-number module needs, handed to the client as inert JSON.
// It asks the traveler nothing about their card, so no card data ships here: just
// the exchange rate, the tourist-tax block, and the default foreign-fee assumption.
const calcData = {
  name: c.name,
  rate: (c.cash && c.cash.rate) || 1, // local currency units per 1 USD
  tax: c.tax || null,
  fallbackFxPct
};
const calcJson = JSON.stringify(calcData).replace(/</g, "\\u003c");

// The opt-in card shortlist, rendered server-side (no JS needed to show it). Three
// cards, ordered for this country. Faces use the TTC palette below, not card-network
// colours or art, so we vary the face colour across the cards rather than mimic a brand.
const shortlist = shortlistFor(c.slug);
const faceColors = ["#0A5644", "#16302C", "#7A3B12", "#4E2436", "#1E3A5F"];
const whyLine = (card) =>
  card.kind === "debit" ? "Fee-free ATM cash worldwide" : "No foreign transaction fee";
const esimBrand = (affiliate.esimBrand && affiliate.esimBrand.trim()) || "";
const ins = affiliate.insurance;
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": (c.faqs || []).map(f => ({
    "@type": "Question", "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
const artLd = {
  "@context": "https://schema.org", "@type": "Article",
  "headline": c.title, "description": c.description,
  "dateModified": c.checkedISO, "datePublished": c.checkedISO,
  "author": { "@type": "Organization", "name": "True Trip Costs" }
};
---
{c.blocked && (
  <section class="blocked">
    <div class="ctx">
      <span>Money briefing</span><span>&middot;</span><span><b style="color:var(--ink)">{c.from} &#8594; {c.name}</b></span>
    </div>
    <h2>We do not cover {c.name} right now.</h2>
    <p set:html={c.blockedNote || "We do not currently publish a money guide for this destination. When a place is under sanctions, off-limits, or the money facts cannot be verified to the standard we hold ourselves to, we would rather show nothing than guess."}></p>
    <p class="bback"><a href="/">Back to all money guides &#8594;</a></p>
  </section>
)}

{!c.blocked && (<Fragment>
<div class={"hero" + (c.hero && c.hero.img ? "" : " solo")}>
  <div class="hcopy">
    <div class="ctx">
      <span>Money briefing</span><span>&middot;</span>
      <span class="ctx-route"><b style="color:var(--ink)">{c.from}</b><span aria-hidden="true">&#8594;</span><span class="ds-wrap">
        <button type="button" class="ds-btn" id="dsBtn" aria-haspopup="listbox" aria-expanded="false" aria-label={"Change destination, currently " + c.name}><b style="color:var(--ink)">{c.name}</b><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="ds-panel" id="dsPanel" hidden>
          <div class="ds-search"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg><input type="text" id="dsSearch" placeholder="Switch country" aria-label="Search for a destination" autocomplete="off" /></div>
          <div class="ds-list" id="dsList" role="listbox">
            {jumpTargets.map(t => (<a class="ds-item" href={'/' + t.slug} data-n={t.name.toLowerCase()}>{t.name}</a>))}
          </div>
          <p class="ds-none" id="dsNone" hidden>No match. <a href="/">See all guides</a>.</p>
        </div>
      </span></span><span>&middot;</span>
      <span class="stamp"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#10502C" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>checked {c.checked}</span>
    </div>
    <h1>{c.h1}</h1>
    <p class="hlede">{c.lede}</p>
  </div>
  {c.hero && c.hero.img && (
    <div class="hart"><img src={c.hero.img} alt={c.hero.alt} width="1100" height={c.hero.h} /></div>
  )}
</div>

<div class="notice" id="notice" set:html={c.notice}></div>

<div class="verdict">
  <span class="vlead">The short version</span>
  <Fragment set:html={c.verdict} />
  <div class="vcta"><a class="btn light" href="#calc">See your honest all-in total
    <svg class="arw" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>
</div>

{c.recentChange && (
  <div class="recentchange">
    <span class="rcpill">Money update &middot; {c.recentChange.date}</span>
    <p set:html={c.recentChange.text}></p>
  </div>
)}

<section>
  <p class="lab">The three things people ask</p>
  <h2>Will my card work? Do I need cash? Are ATMs easy?</h2>
  <p class="sub">The quick read for a first trip.</p>
  <div class="trio">
    {c.trio.map(t => (
      <div class={"vc " + t.kind}>
        <Symbol name={t.sym} cls="sym" />
        <div class="bd">
          <h3>{t.h}</h3>
          <p class="verd">{t.verd}</p>
          <p>{t.p}</p>
          <a class="cta" href={t.cta.href === "#" ? "#calcNoFee" : t.cta.href}>{t.cta.label} <span class="arw">&#8594;</span></a>
        </div>
      </div>
    ))}
  </div>
</section>

<section>
  <p class="lab">Cash or card</p>
  <h2>{c.meter.heading}</h2>
  <div class="meter">
    <div class="meterhead">
      <span class="ml cash"><span class="mdot"></span>about {c.meter.cashPct}% cash</span>
      <span class="ml card"><span class="mdot"></span>{100 - c.meter.cashPct}% card</span>
    </div>
    <div class="meterbar" aria-hidden="true">
      <div class="cash" style={"width:" + c.meter.cashPct + "%"}></div>
      <div class="cardp" style={"width:" + (100 - c.meter.cashPct) + "%"}></div>
    </div>
    <p class="meternote">{c.meter.note}</p>
    <a class="cta" href="#cash">See how much cash to plan for <span class="arw">&#8594;</span></a>
  </div>
</section>

<section>
  <p class="lab">Your money plan</p>
  <h2>Four steps and you're set.</h2>
  <div class="plan">
    {c.plan.map(p => (
      <div class="pstep">
        <Symbol name={p.sym} cls="psym" />
        <div class="pbody">
          <h3 class="pwhen">{p.when}</h3>
          <ul>{p.bullets.map(b => (<li set:html={b}></li>))}</ul>
          {p.cta && (
            <a class="cta" href={p.cta.href === "#" ? "#calcNoFee" : p.cta.href}>{p.cta.label}
              <span class={"tg " + p.cta.tag}>{p.cta.tag === "earn" ? "we may earn a commission" : "we earn nothing"}</span>
              <span class="arw">&#8594;</span></a>
          )}
          {ins && p.when === "Before you go" && (
            <div style="border-top:1px solid var(--line);margin-top:14px;padding-top:12px">
              <p style="font-size:14px;color:#3B4A46;margin:0"><b>Travel insurance, if it fits the trip.</b> Worth it when you have prepaid a lot or are somewhere with steep medical costs. If your trip is cheap and refundable, you can skip it.</p>
              <a class="cta" href={ins}>Compare Faye's whole-trip cover
                <span class="tg earn">we may earn a commission</span>
                <span class="arw">&#8594;</span></a>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

{/* The cash estimator now sits beneath the honest number, as a secondary helper. See the #cash section after #calc. */}

{c.connectivity && (
<section>
  <p class="lab">Staying connected</p>
  <h2>Will my phone work here? And what will it cost?</h2>
  <p class="sub">{c.connectivity.works} The cost is where people get caught out, and on most US plans it lands in one of two buckets.</p>
  <div class="trio">
    <div class="vc ok">
      <Symbol name="phoneok" cls="sym" />
      <div class="bd">
        <h3>{(c.connectivity.covered && c.connectivity.covered.h) || "Your plan may already include it"}</h3>
        <p class="verd">{(c.connectivity.covered && c.connectivity.covered.verd) || "Often, do nothing"}</p>
        <p>{(c.connectivity.covered && c.connectivity.covered.p) || "Some US plans include slow data abroad at no extra cost. If that is you, the honest move is to leave it alone."}</p>
        <p style="margin-top:8px"><span class="tg free">we earn nothing</span></p>
      </div>
    </div>
    <div class="vc warn">
      <Symbol name="roamfee" cls="sym" />
      <div class="bd">
        <h3>{(c.connectivity.charged && c.connectivity.charged.h) || "Or it charges quietly, after the fact"}</h3>
        <p class="verd">{(c.connectivity.charged && c.connectivity.charged.verd) || "The bill lands later"}</p>
        <p>{(c.connectivity.charged && c.connectivity.charged.p) || "On pay-per-use plans the cost runs in the background while you travel, and the charge can show up weeks after you are home. Forgetting to switch off data roaming is the classic one. For a week or more, an eSIM is usually cheaper and keeps you in control."}</p>
      </div>
    </div>
  </div>
  <p style="font-size:14.5px;margin:16px 0 0">Check what your own carrier charges before the trip, not after.</p>
  {esim && (
    <Fragment>
      <p style="font-size:14.5px;margin:6px 0 0">If an eSIM is the cheaper call, {esimBrand ? `${esimBrand} covers ${c.name}.` : `there is a tracked eSIM option for ${c.name}.`}</p>
      <a class="cta" href={esim}>{esimBrand ? `Get your ${esimBrand} eSIM for ${c.name}` : `Get an eSIM for ${c.name}`}
        <span class="tg earn">we may earn a commission</span>
        <span class="arw">&#8594;</span></a>
    </Fragment>
  )}
</section>
)}

<section>
  <p class="lab">Currency basics</p>
  <h2>{c.currencyHeading}</h2>
  <div class="facts">
    {c.facts.map(f => (
      <div class="fact">
        <Symbol name={f.sym} cls="fsym" />
        <div><p class="k">{f.k}</p><p class="v">{f.v}</p></div>
      </div>
    ))}
  </div>
</section>

{c.taxfree && (
  <section>
    <p class="lab">{c.taxfree.label || "Tax-free shopping"}</p>
    <h2>{c.taxfree.heading}</h2>
    <p class="sub" set:html={c.taxfree.text}></p>
  </section>
)}

<section>
  <p class="lab">Watch out for</p>
  <h2>The small traps that catch first-timers.</h2>
  <div class="traps">
    {c.traps.map(t => (<div class="trap"><span class="dot">!</span><span set:html={t}></span></div>))}
  </div>
</section>

<section>
  <p class="lab">Tipping</p>
  <h2>{c.tippingHeading}</h2>
  <p class="sub">{c.tipping}</p>
</section>

<section>
  <p class="lab">Common questions</p>
  <h2>Quick answers.</h2>
  <div class="faq">
    {c.faqs.map(f => (<div class="faqitem"><h3>{f.q}</h3><p>{f.a}</p></div>))}
  </div>
</section>

<section id="calc">
  <p class="lab">The honest number</p>
  <h2>Your real all-in total for {c.name}.</h2>
  <p class="sub">Put in a hotel price and we add {c.name}'s tourist tax and the foreign card fee most US cards charge, so the number you see is the number you pay. No bank to pick, no sign-up, nothing saved.</p>

  <!-- Everything the module needs, handed over as inert JSON (Astro leaves application/json untouched). No card data ships: it asks the traveler nothing about their card. -->
  <script type="application/json" id="hn-data" set:html={calcJson}></script>

  <div class="hn" id="hn-app" hidden>
    <div class="hn-inputs">
      <label class="cf" id="hnRegionWrap" hidden style="display:none">
        <span class="cf-l">Where are you staying?</span>
        <span class="selwrap"><select id="hnRegion"></select></span>
      </label>
      <label class="cf">
        <span class="cf-l">Hotel price a night</span>
        <span class="moneyin"><span class="mny">$</span><input id="hnRoom" type="text" inputmode="numeric" value="150" aria-label="Hotel price per night in US dollars" /></span>
      </label>
      <div class="calc-pair">
        <div class="cf">
          <span class="cf-l">Nights</span>
          <span class="stepper">
            <button type="button" class="stp" data-step="hnNights" data-dir="-1" aria-label="One fewer night">&#8722;</button>
            <span class="stp-v" id="hnNights" data-v="5">5</span>
            <button type="button" class="stp" data-step="hnNights" data-dir="1" aria-label="One more night">+</button>
          </span>
        </div>
        <div class="cf">
          <span class="cf-l">Travelers</span>
          <span class="stepper">
            <button type="button" class="stp" data-step="hnTrav" data-dir="-1" aria-label="One fewer traveler">&#8722;</button>
            <span class="stp-v" id="hnTrav" data-v="2">2</span>
            <button type="button" class="stp" data-step="hnTrav" data-dir="1" aria-label="One more traveler">+</button>
          </span>
        </div>
      </div>
      <label class="hn-toggle">
        <input type="checkbox" id="hnNoFee" />
        <span class="hn-switch" aria-hidden="true"></span>
        <span class="hn-toggle-l">I have a no-foreign-fee card</span>
      </label>
    </div>

    <div class="hn-result" aria-live="polite">
      <div class="hn-rows">
        <div class="hn-line"><span class="hn-k">Room (<span id="hnNightsLabel">5</span> nights)</span><span class="hn-v num" id="hnRoomV">$750</span></div>
        <div class="hn-line"><span class="hn-k" id="hnTaxLabel">Tourist tax</span><span class="hn-v num" id="hnTax">$0</span></div>
        <div class="hn-line hn-fee" id="hnFeeLine"><span class="hn-k">Foreign card fee <span class="hn-feeq" id="hnFeeQ">(about 3%)</span></span><span class="hn-v num" id="hnFee">$22</span></div>
      </div>
      <div class="hn-total">
        <span class="hn-total-k">Honest total</span>
        <span class="hn-total-v num" id="hnTotal">$772</span>
      </div>
      <p class="hn-over" id="hnOver" hidden></p>
      <p class="hn-feenote" id="hnFeeNote">Most US cards add about 3% on foreign purchases, so that is included here.</p>
      <p class="hn-note" id="hnTaxNote" hidden></p>
      <p class="hn-fine">Rough guide, not a quote. We assume the room goes on the card and the tourist tax is paid at the hotel, often in cash, so the card fee is figured on the room. Rates checked Jun 2026 and rounded.</p>
    </div>
  </div>

  <noscript>
    <div class="reveal"><div class="t">The all-in total needs JavaScript switched on. With it off: take the room price, add {c.name}'s tourist tax, and add about 3% for a typical US card's foreign fee.</div></div>
  </noscript>

  <details class="cardlist" id="calcNoFee">
    <summary class="cardlist-sum">
      <span class="cardlist-txt"><b>Not sure which card to bring?</b> See <span class="cardlist-link">my pick for {c.name}</span>.</span>
      <svg class="cardlist-chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </summary>
    <div class="cardlist-body">
      <div style="display:flex;gap:9px;align-items:flex-start;background:#E1F1EB;border-radius:12px;padding:11px 13px;margin:0 0 14px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#15803D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
        <p style="margin:0;font-size:14px;line-height:1.5;color:#0A5644"><b>Already carry a card with no foreign transaction fee?</b> Then you are set for {c.name}, and can skip this. There is nothing to buy.</p>
      </div>
      <p class="sl-intro">{shortlist[0] && shortlist[0].kind === "debit"
        ? `${c.name} leans on cash more than its reputation suggests, so the card that earns its place is a fee-free ATM debit card, with a no-foreign-fee credit card for hotels and bigger spots. If you are getting one, this is the pairing I would pick.`
        : `If you are getting a card for ${c.name}, this is the pairing I would pick: a no-foreign-fee credit card for spending, and a fee-free ATM debit card for cash.`} We earn nothing on these today. Always confirm the current fee with the issuer before you apply. Checked {cardsChecked}.</p>
      <div class="sl-row" role="list">
        {shortlist.map((card, i) => (
          <div class="sl" role="listitem">
            {i === 0 && <div style="margin:0 0 8px"><span style="display:inline-block;background:#0A5644;color:#fff;font-size:11px;font-weight:500;padding:2px 10px;border-radius:999px">My pick for {c.name}</span></div>}
            <div class="sl-face" style={`--f:${faceColors[i % faceColors.length]}`}>
              <div class="sl-top"><span class="sl-bank">{card.issuer}</span><span class="sl-chip" aria-hidden="true"></span></div>
              <div class="sl-stripe" aria-hidden="true"></div>
              <span class="sl-prod">{card.product}</span>
              <div class="sl-foot"><span class="sl-net">{(card.network || '').toUpperCase()}</span><span class="sl-mark" aria-hidden="true">TTC</span></div>
            </div>
            <p class="sl-why">{(i === 0 && card.note) ? card.note : whyLine(card)}</p>
            <div style="margin:0 0 6px"><span style="display:inline-block;background:#E1F1EB;color:#0A5644;font-size:11.5px;font-weight:500;padding:3px 9px;border-radius:999px">{card.kind === "debit" ? "Best for ATM cash" : "Best for hotels, shops, dining"}</span></div>
            <span class={"tg " + (card.affiliate && card.affiliate.link ? "earn" : "free")}>{(card.affiliate && card.affiliate.label) || "we earn nothing"}</span>
          </div>
        ))}
      </div>
      <div style="display:flex;gap:9px;align-items:flex-start;border:1px solid var(--line);border-radius:12px;padding:11px 13px;margin:14px 0 0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0A5644" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
        <p style="margin:0;font-size:13px;line-height:1.55;color:#5C6661">Recommended with no kickback from any of these. If that ever changes, this label will read <i>we may earn a commission</i>, and the pick will still be the pick.</p>
      </div>
    </div>
  </details>
</section>

<section id="cash">
  <p class="lab">How much cash</p>
  <h2>A sensible amount to plan for.</h2>
  <p class="sub">A helper on top of the total above: on-the-ground spending for your whole group across the trip, food, local transport, activities and tips. Lodging is left out on purpose, since it is usually prepaid or paid by card.</p>
  <div class="estimator secondary" data-rate={c.cash.rate} data-cur={c.cash.cur} data-round={c.cash.round || 100000} data-fx={fallbackFxPct}>
    <div class="erow">
      <div class="ef"><label for="trav">Travelers</label>
        <div class="step">
          <button type="button" class="stepdn" aria-label="Fewer travelers">&#8722;</button>
          <input id="trav" type="number" inputmode="numeric" min="1" max="12" value="2" aria-label="Number of travelers">
          <button type="button" class="stepup" aria-label="More travelers">+</button>
        </div>
      </div>
      <div class="ef"><label for="days">Days</label>
        <div class="step">
          <button type="button" class="stepdn" aria-label="Fewer days">&#8722;</button>
          <input id="days" type="number" inputmode="numeric" min="1" max="60" value="7" aria-label="Number of days">
          <button type="button" class="stepup" aria-label="More days">+</button>
        </div>
      </div>
      <div class="ef"><label>Style</label>
        <div class="seg" role="group" aria-label="Travel style">
          {c.cash.styles.map((s, i) => (
            <button id={"s" + i} class={i === c.cash.defaultIndex ? "on" : ""} type="button" data-per={s.per} data-cash={s.cash}>{s.n}</button>
          ))}
        </div>
      </div>
    </div>
    <div class="ebig">Plan about <span class="amt num" id="total">$700</span> across the trip.</div>
    <p class="escope">About <b id="perday" class="num">$50</b> per person a day, for <b id="ntrav" class="num">2</b> travelers over <b id="ndays" class="num">7</b> days.</p>
    <div class="esplit">
      <div class="ebar" aria-hidden="true"><div class="c1" id="cashBar" style="width:70%"></div><div class="c2" id="cardBar" style="width:30%"></div></div>
      <div class="elegend"><span class="el cash"><span class="mdot"></span>cash <b id="cashUsd">$490</b></span><span class="el card"><span class="mdot"></span>card <b id="cardUsd">$210</b></span></div>
    </div>
    <p class="ehint">That means pulling roughly <b id="vnd">12,000,000</b> in cash, in about <b id="pulls">2</b> ATM <span id="visitword">visits</span>. {c.cash.rateNote}</p>
    <p class="enote">Both sides carry a quiet cost. Pulling cash from a foreign ATM costs a few dollars unless you use a no-fee debit card, and a typical US card adds about <b id="cardFee" class="num">$6</b> on that card spending. A no-fee card pairing makes both $0.</p>
    <a class="cta" href="#calcNoFee">See the cards that skip both fees <span class="tg free">we earn nothing</span> <span class="arw">&#8594;</span></a>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqLd)}></script>
<script type="application/ld+json" set:html={JSON.stringify(artLd)}></script>

<script>
  (function () {
    var b = document.getElementById('dsBtn'); if (!b) return;
    var p = document.getElementById('dsPanel'), s = document.getElementById('dsSearch');
    var list = document.getElementById('dsList'), none = document.getElementById('dsNone');
    var items = Array.prototype.slice.call(list.querySelectorAll('.ds-item'));
    function open(o) { p.hidden = !o; b.setAttribute('aria-expanded', o ? 'true' : 'false'); if (o) { s.value = ''; filt(); s.focus(); } }
    function filt() {
      var q = (s.value || '').trim().toLowerCase(); var n = 0;
      items.forEach(function (it) { var sh = !q || it.getAttribute('data-n').indexOf(q) > -1; it.style.display = sh ? '' : 'none'; if (sh) n++; });
      if (none) none.hidden = !!n;
    }
    b.addEventListener('click', function (e) { e.stopPropagation(); open(p.hidden); });
    s.addEventListener('input', filt);
    s.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('click', function (e) { if (!p.hidden && !p.contains(e.target) && !b.contains(e.target)) open(false); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !p.hidden) open(false); });
  })();
