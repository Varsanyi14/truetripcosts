<script>
  function n(id){return document.getElementById(id);}
  const est = document.querySelector('.estimator');
  if (est) {
    const rate = +est.dataset.rate, cur = est.dataset.cur, round = +est.dataset.round || 100000;
    const fx = +est.dataset.fx || 3;
    const btns = Array.from(est.querySelectorAll('.seg button'));
    let si = btns.findIndex(b => b.classList.contains('on')); if (si < 0) si = 0;
    const reduce = window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches;
    const usd = x => '$' + Math.round(x).toLocaleString('en-US');
    const loc = x => (Math.round(x / round) * round).toLocaleString('en-US') + ' ' + cur;
    // Smoothly roll a number from its previous value to the new one.
    function roll(el, to, fmt, animate) {
      if (!el) return;
      const from = (el._v == null) ? to : el._v; el._v = to;
      if (!animate || reduce || from === to) { el.textContent = fmt(to); return; }
      const t0 = performance.now(), dur = 420;
      (function step(now) {
        const p = Math.min(1, (now - t0) / dur), e = 1 - Math.pow(1 - p, 3);
        el.textContent = fmt(from + (to - from) * e);
        if (p < 1) requestAnimationFrame(step);
      })(t0);
    }
    function calc(animate) {
      const trav = Math.max(1, +n('trav').value || 1), days = Math.max(1, +n('days').value || 1);
      const b = btns[si], per = +b.dataset.per, cashShare = +b.dataset.cash;
      const total = per * trav * days, cash = total * cashShare, card = total - cash;
      roll(n('total'), total, usd, animate);
      roll(n('perday'), per, usd, animate);
      n('ntrav').textContent = trav; n('ndays').textContent = days;
      const cp = Math.round(cashShare * 100);
      n('cashBar').style.width = cp + '%'; n('cardBar').style.width = (100 - cp) + '%';
      roll(n('cashUsd'), cash, usd, animate);
      roll(n('cardUsd'), card, usd, animate);
      roll(n('cardFee'), card * fx / 100, usd, animate);
      const pulls = Math.max(1, Math.ceil(cash / 300));
      roll(n('vnd'), cash * rate, loc, animate); n('pulls').textContent = pulls;
      const vw = n('visitword'); if (vw) vw.textContent = pulls === 1 ? 'visit' : 'visits';
    }
    btns.forEach((b, i) => b.addEventListener('click', () => { si = i; btns.forEach((x, j) => x.classList.toggle('on', j === i)); calc(true); }));
    function clamp(v, lo, hi){ return Math.max(lo, Math.min(hi, v)); }
    function wireStep(id) {
      const input = n(id), wrap = input.closest('.step');
      if (!wrap) return;
      const lo = +input.min || 1, hi = +input.max || 999;
      const dn = wrap.querySelector('.stepdn'), up = wrap.querySelector('.stepup');
      function limits(v) { if (dn) dn.disabled = v <= lo; if (up) up.disabled = v >= hi; }
      function set(v) { v = clamp(Math.round(v), lo, hi); input.value = v; limits(v); calc(true); }
      if (dn) dn.addEventListener('click', () => set((+input.value || lo) - 1));
      if (up) up.addEventListener('click', () => set((+input.value || lo) + 1));
      input.addEventListener('input', () => { limits(+input.value); calc(true); });
      input.addEventListener('blur', () => { if (input.value !== '') set(+input.value || lo); });
      limits(+input.value || lo);
    }
    wireStep('trav'); wireStep('days');
    calc(false);
  }
</script>

<script>
  // The honest number. Reads the inert JSON in #hn-data (exchange rate, the country's
  // tourist-tax block, the default foreign-fee assumption), runs the tax engine, and
  // renders one all-in total. It asks the traveler nothing about their card: a single
  // toggle decides whether the typical foreign fee is included. No data leaves the page.
  // Same vanilla DOM approach as the cash estimator above.
  (function () {
    const app = document.getElementById('hn-app');
    const dataEl = document.getElementById('hn-data');
    if (!app || !dataEl) return;

    let DATA;
    try { DATA = JSON.parse(dataEl.textContent); } catch (e) { return; }

    const rate = DATA.rate || 1;                 // local currency units per 1 USD
    const tax = DATA.tax || null;
    const fallbackFxPct = (DATA.fallbackFxPct != null) ? DATA.fallbackFxPct : 3;

    const id = x => document.getElementById(x);
    const usd = x => '$' + Math.round(x).toLocaleString('en-US');
    const fmtPct = p => (Number.isInteger(p) ? p : Math.round(p * 10) / 10) + '%';
    const esc = s => String(s).replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    const state = {
      regionIndex: 0,
      room: 150,
      nights: 5,
      trav: 2,
      noFee: false
    };

    // ----- region selector (only when the tax varies by place) -----
    const regionWrap = id('hnRegionWrap');
    const regionSel = id('hnRegion');
    const regions = (tax && Array.isArray(tax.regions)) ? tax.regions : [];
    if (regions.length > 1) {
      regionSel.innerHTML = regions.map((r, i) => '<option value="' + i + '">' + esc(r.label) + '</option>').join('');
      regionWrap.hidden = false;
      regionWrap.style.display = '';
      regionSel.addEventListener('change', () => { state.regionIndex = +regionSel.value || 0; render(); });
    } else {
      regionWrap.hidden = true;
      regionWrap.style.display = 'none';
    }

    // ----- room money input -----
    const roomInput = id('hnRoom');
    function roomVal() {
      let v = parseInt(String(roomInput.value).replace(/[^0-9]/g, ''), 10);
      if (isNaN(v) || v < 0) v = 0;
      return v;
    }
    roomInput.addEventListener('input', () => { state.room = roomVal(); render(); });
    roomInput.addEventListener('blur', () => { roomInput.value = state.room ? state.room.toLocaleString('en-US') : ''; });

    // ----- steppers (nights, travelers) -----
    const limits = { hnNights: [1, 60], hnTrav: [1, 12] };
    function bindStepper(key) {
      const el = id(key);
      const lo = limits[key][0], hi = limits[key][1];
      const btns = Array.from(app.querySelectorAll('.stp[data-step="' + key + '"]'));
      function setDisabled(v) {
        btns.forEach(b => { b.disabled = (b.dataset.dir === '-1' && v <= lo) || (b.dataset.dir === '1' && v >= hi); });
      }
      btns.forEach(btn => btn.addEventListener('click', () => {
        let v = +el.dataset.v + (+btn.dataset.dir);
        v = Math.max(lo, Math.min(hi, v));
        el.dataset.v = v; el.textContent = v;
        if (key === 'hnNights') state.nights = v; else state.trav = v;
        setDisabled(v);
        render();
      }));
      setDisabled(+el.dataset.v);
    }
    bindStepper('hnNights');
    bindStepper('hnTrav');

    // ----- the one optional control: a no-foreign-fee card toggle -----
    const noFeeToggle = id('hnNoFee');
    if (noFeeToggle) {
      noFeeToggle.addEventListener('change', () => { state.noFee = noFeeToggle.checked; render(); });
    }

    // ----- tourist-tax engine. rate = local currency units per 1 USD. -----
    function computeTax(roomUSD, nights, trav) {
      if (!tax || tax.none || regions.length === 0) {
        return { usd: 0, label: 'Tourist tax', note: (tax && tax.note) || '' };
      }
      const r = regions[Math.min(state.regionIndex, regions.length - 1)] || regions[0];
      const unit = r.unit || tax.unit;
      const capRaw = (r.capNights !== undefined) ? r.capNights : tax.capNights;
      const cap = (capRaw == null) ? null : capRaw;
      const nCap = cap ? Math.min(nights, cap) : nights;

      let amount = 0;
      if (unit === 'perPersonPerNight') {
        amount = ((r.rate || 0) * trav * nCap) / rate;
      } else if (unit === 'flatPerNight') {
        amount = ((r.rate || 0) * nCap) / rate;               // per booking, not per person
      } else if (unit === 'percentOfRoom') {
        amount = ((r.pct || 0) / 100) * roomUSD * nCap;        // already USD, per booking
      } else if (unit === 'tieredPerPersonPerNight') {
        const bands = r.bands || [];
        const ppLocalNight = (roomUSD / Math.max(1, trav)) * rate;
        let band = 0;
        for (const b of bands) { if (b.upTo == null || ppLocalNight < b.upTo) { band = b.rate; break; } }
        amount = (band * trav * nCap) / rate;
      }
      if (r.oneTimePerPerson) amount += (r.oneTimePerPerson * trav) / rate;   // e.g. Mexico VISITAX

      const short = String(r.label).split(' (')[0];
      let label;
      if (amount <= 0) label = 'Tourist tax';
      else if (r.taxLabel) label = r.taxLabel;
      else if (tax.taxLabel) label = tax.taxLabel;
      else label = short + ' tourist tax';

      return { usd: amount, label: label, note: r.note || tax.note || '' };
    }

    function render() {
      const roomUSD = state.room, nights = state.nights, trav = state.trav;
      const roomSub = roomUSD * nights;
      const t = computeTax(roomUSD, nights, trav);
      const pct = state.noFee ? 0 : fallbackFxPct;
      const fee = roomSub * (pct / 100);
      const total = roomSub + t.usd + fee;

      id('hnNightsLabel').textContent = nights;
      id('hnRoomV').textContent = usd(roomSub);
      id('hnTaxLabel').textContent = t.label;
      id('hnTax').textContent = usd(t.usd);
      id('hnFeeQ').textContent = '(about ' + fmtPct(fallbackFxPct) + ')';
      id('hnFee').textContent = usd(fee);
      id('hnTotal').textContent = usd(total);

      // Fee line greys out and reads $0 when the no-fee card toggle is on.
      const feeLine = id('hnFeeLine');
      if (state.noFee) feeLine.classList.add('off'); else feeLine.classList.remove('off');

      // The note under the total swaps with the toggle.
      const fn = id('hnFeeNote');
      fn.textContent = state.noFee
        ? 'No card fees included.'
        : 'Most US cards add about ' + fmtPct(fallbackFxPct) + ' on foreign purchases, so that is included here.';

      // Per-region tourist-tax note, if any.
      const tn = id('hnTaxNote');
      if (t.note) { tn.textContent = t.note; tn.hidden = false; } else { tn.hidden = true; }

      // How much the honest total runs over the bare room price.
      const over = id('hnOver');
      const extra = total - roomSub;
      if (roomSub <= 0) {
        over.hidden = true;
      } else if (extra > 0) {
        over.hidden = false;
        over.textContent = 'About ' + usd(extra) + ' over the room price.';
      } else {
        over.hidden = false;
        over.textContent = 'That is the room price, nothing hidden.';
      }
    }

    // ----- init -----
    app.hidden = false;
    state.room = roomVal();
    render();
  })();

  // Open the curated card shortlist when an in-page link points at it, and honour a
  // #calcNoFee deep link on load or hash change. It is a native <details>, so it still
  // opens without this; this just wires the "see cards" links and the cash-helper link.
  (function () {
    const box = document.getElementById('calcNoFee');
    if (!box) return;
    function open() {
      box.open = true;
      try { box.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) { box.scrollIntoView(); }
    }
    document.querySelectorAll('a[href="#calcNoFee"]').forEach(a => {
      a.addEventListener('click', () => { box.open = true; });
    });
    if (location.hash === '#calcNoFee') open();
    window.addEventListener('hashchange', () => { if (location.hash === '#calcNoFee') open(); });
  })();
</script>
