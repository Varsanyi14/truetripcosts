<script>
  const g = document.querySelector(".ins-gauge");
  if (g) {
    const ds = document.querySelector(".ins-ds");
    const order = ["low", "medium", "high"];
    const track = g.querySelector(".ins-track");
    const set = (lvl) => {
      if (!order.includes(lvl)) return;
      g.dataset.level = lvl;
      g.setAttribute("aria-valuenow", String(order.indexOf(lvl) + 1));
      g.setAttribute("aria-valuetext", lvl);
      const text = g.dataset[lvl];
      if (ds && text) ds.textContent = text;
    };
    const fromX = (clientX) => {
      const r = track.getBoundingClientRect();
      const p = (clientX - r.left) / r.width;
      set(p < 1 / 3 ? "low" : p < 2 / 3 ? "medium" : "high");
    };
    let dragging = false;
    g.addEventListener("pointerdown", (e) => { dragging = true; try { g.setPointerCapture(e.pointerId); } catch (_) {} fromX(e.clientX); });
    g.addEventListener("pointermove", (e) => { if (dragging) fromX(e.clientX); });
    const stop = () => { dragging = false; };
    g.addEventListener("pointerup", stop);
    g.addEventListener("pointercancel", stop);
    g.addEventListener("keydown", (e) => {
      const i = order.indexOf(g.dataset.level);
      if ((e.key === "ArrowRight" || e.key === "ArrowUp") && i < 2) { set(order[i + 1]); e.preventDefault(); }
      if ((e.key === "ArrowLeft" || e.key === "ArrowDown") && i > 0) { set(order[i - 1]); e.preventDefault(); }
    });
  }
</script>

