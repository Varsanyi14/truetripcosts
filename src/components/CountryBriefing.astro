  .rel-sub{font-size:14.5px;color:var(--muted);line-height:1.5;margin:0 0 16px;max-width:640px}
  .rel-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px}
  .rel-card{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:13px 15px;border:1px solid var(--line);border-radius:var(--radius);background:var(--card);box-shadow:var(--shadow);text-decoration:none}
  .rel-card:hover{border-color:var(--teal)}
