---
import Symbol from './Symbol.astro';
import NewTab from './NewTab.astro';
import { affiliate, esimLink, visaLink } from '../data/links.js';
import { fallbackFxPct, shortlistFor, cardsChecked, wiseCard } from '../data/cards.js';
import { countries } from '../data/index.js';
import { regionOf, REGIONS, REGION_PHRASE } from '../data/hubs.js';
import fxFallback from '../data/fxFallback.js';
import fs from 'node:fs';
const { country: c } = Astro.props;
// Flag per related country, matching the homepage and hubs: /flags/<slug>.svg,
// falling back to the globe so nothing ever renders broken.
const flagDir = process.cwd() + '/public/flags/';
const flagSrc = (slug) => fs.existsSync(flagDir + slug + '.svg') ? '/flags/' + slug + '.svg' : '/flags/world.svg';
const jumpTargets = countries.filter(x => x.live && !x.blocked && x.slug !== c.slug).sort((a, b) => a.name.localeCompare(b.name));
// Region, region hub and the same-region cluster, all from the shared hub source so
// they stay consistent with the hubs and breadcrumbs.
const myRegion = regionOf(c);
const regionPhrase = (REGION_PHRASE && REGION_PHRASE[myRegion]) || myRegion;
const related = jumpTargets.filter(x => regionOf(x) === myRegion);
const regionHub = myRegion ? REGIONS[myRegion] : null;
const regionHubLive = !!(regionHub && regionHub.live);
// Home > Region > Country breadcrumb, mirrored as BreadcrumbList JSON-LD. The region
// step appears only once that region hub is live.
const crumbBase = 'https://truetripcosts.com';
const crumbItems = [{ name: 'Home', url: crumbBase + '/' }];
if (regionHubLive) crumbItems.push({ name: regionHub.label, url: crumbBase + '/' + regionHub.slug });
crumbItems.push({ name: c.name, url: crumbBase + '/' + c.slug });
const crumbLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: crumbItems.map((it, i) => ({ '@type': 'ListItem', position: i + 1, name: it.name, item: it.url })) };
const esim = esimLink(c.slug);
const visaExp = visaLink(c.slug);

// Sources display: split each source label into a name (before the colon) and a
// short note (what it verifies), then pick an icon from its type. Type is read
// from the data when present, and inferred from the publisher name otherwise, so
// every country renders in the same shape.
const SRC_ICONS = {
  revenue: '<path d="M3 21h18"></path><path d="M4 10h16"></path><path d="M6 10v11M10 10v11M14 10v11M18 10v11"></path><path d="M12 3 4 8h16z"></path>',
  gov: '<path d="M6 3v18"></path><path d="M6 4h12l-2 3.5L18 11H6"></path>',
  tourism: '<path d="M12 21s6.5-5.2 6.5-10.5a6.5 6.5 0 1 0-13 0C5.5 15.8 12 21 12 21z"></path><circle cx="12" cy="10.5" r="2.4"></circle>',
  police: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path><path d="m9 12 2 2 4-4"></path>',
  currency: '<rect x="3" y="6" width="18" height="12" rx="2"></rect><circle cx="12" cy="12" r="2.5"></circle><path d="M6.5 9.5h.01M17.5 14.5h.01"></path>',
  card: '<rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 10h18"></path><path d="M7 15h4"></path>',
  media: '<path d="M4 5h13v14H5a1 1 0 0 1-1-1z"></path><path d="M17 8h3v9a2 2 0 0 1-2 2"></path><path d="M7 9h7M7 13h7M7 16h4"></path>',
  guide: '<path d="M12 6C9.5 4.5 6.5 4.5 4 5v13c2.5-.5 5.5-.5 8 1 2.5-1.5 5.5-1.5 8-1V5c-2.5-.5-5.5-.5-8 1z"></path><path d="M12 6v13"></path>',
  doc: '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path><path d="M14 3v5h5"></path><path d="M9 13h6M9 17h4"></path>'
};
function srcType(label, explicit) {
  if (explicit && SRC_ICONS[explicit]) return explicit;
  const p = (label.split(': ')[0] || '').toLowerCase();
  if (/police|emergency/.test(p)) return 'police';
  if (/central bank|reserve bank|monetary authority|state bank/.test(p)) return 'currency';
  if (/herald|news daily|\bnews\b|times|gazette|magazine/.test(p)) return 'media';
  if (/\bguide\b|\bblog\b/.test(p)) return 'guide';
  if (/tourism|tourist|visit |visitors|\.travel/.test(p)) return 'tourism';
  if (/revenue|tax authorit|tax administration|ministry of finance|federal tax|inland revenue|\bdian\b|\baade\b/.test(p)) return 'revenue';
  if (/issuer|\batm\b|mastercard|\bvisa\b/.test(p)) return 'card';
  return 'gov';
}
function srcParts(s) {
  const i = s.label.indexOf(': ');
  const name = i === -1 ? s.label : s.label.slice(0, i);
  const note = i === -1 ? '' : s.label.slice(i + 2);
  return { name, note, icon: SRC_ICONS[srcType(s.label, s.type)] || SRC_ICONS.doc };
}
// Outbound links (the eSIM, insurance, and any plan or tax call to action that
// points to a real URL) open in a new tab, so the guide stays open behind them.
// noopener closes the reverse-tab security hole, sponsored is the marker Google
// asks for on paid links, and internal anchors like #calc or /japan are left alone.
// The test is the URL itself, so a link that is not live yet stays in the same tab.
const dest = (cta) => (cta && cta.href && cta.href !== "#") ? cta.href : "#calcNoFee";
const ext = (h, paid = true) => (typeof h === "string" && /^https?:\/\//i.test(h)) ? { target: "_blank", rel: paid ? "noopener sponsored" : "noopener" } : {};
// The ATM card's button opens a Google Maps search for cash machines in this
// country, built from the name we already store, so it is one default for every
// country and needs nothing set per country. It is a reference link, not a paid
// one, so it opens in a new tab with noopener only, no sponsored.
const atmMap = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent("ATM in " + c.name);
// Everything the honest-number module needs, handed to the client as inert JSON.
// It asks the traveler nothing about their card, so no card data ships here: just
// the exchange rate, the tourist-tax block, and the default foreign-fee assumption.
const calcData = {
  name: c.name,
  rate: (c.cash && c.cash.rate) || 1, // local currency units per 1 USD
  cur: (c.cash && c.cash.cur) || "",
  round: (c.cash && c.cash.round) || 100000,
  rateNote: (c.cash && c.cash.rateNote) || "",
  tax: c.tax || null,
  fallbackFxPct
};
const calcJson = JSON.stringify(calcData).replace(/</g, "\\u003c");

// The opt-in card shortlist, rendered server-side (no JS needed to show it). Three
// cards, ordered for this country. Faces use the TTC palette below, not card-network
// colours or art, so we vary the face colour across the cards rather than mimic a brand.
const shortlist = shortlistFor(c.slug);
// Wise gets its own quick-card below the three merit picks (a distinct module, not
// a fourth tile). Its link and "we may earn a commission" label are data-driven
// from cards.js, so it lights up site-wide the moment the URL is set there, exactly
// like the other paid picks. The three merit tiles above stay untouched and unpaid.
const wiseLink = (wiseCard && wiseCard.affiliate && wiseCard.affiliate.link) || null;
const wiseNote = (wiseCard && wiseCard.note) || "";
const faceColors = ["#0A5644", "#16302C", "#7A3B12", "#4E2436", "#1E3A5F"];
const whyLine = (card) =>
  card.kind === "debit" ? "Fee-free ATM cash worldwide" : "No foreign transaction fee";
const esimBrand = (affiliate.esimBrand && affiliate.esimBrand.trim()) || "";
// Medical-cover card. Two picks on a spectrum, both reading their link from
// links.js so each label flips on its own the day a program lands (same rule as
// the card tags). insFaye is the whole-trip pick; insMedical is the deeper
// travel-medical pick, added to links.js as affiliate.medical when that program
// lands. Until then affiliate.medical is undefined, which the ext() plumbing
// handles gracefully: the pick shows, carries no link, and reads "we earn nothing".
const insFaye = affiliate.insurance;
const insMedical = affiliate.medical;
// Standalone rental-car excess cover (RentalCover, via Rakuten). One link covers
// every country; the section renders only on guides flagged rentalCommon in their
// data file. carExcessBrand is the name shown on the button, so switching providers
// later is a one-line change. Until affiliate.carExcess holds a URL, the block still
// shows its guidance and reads "we earn nothing" with no button, the same graceful
// null the eSIM and medical slots use.
const carExcess = affiliate.carExcess;
const carBrand = (affiliate.carExcessBrand && affiliate.carExcessBrand.trim()) || "RentalCover";

// Currency anchor panel. Reads each guide's existing `currency` ISO code, so a
// new country needs no rate setup at all. Currencies at par with the US dollar
// (the dollar itself, and those pegged one to one) show a short "no need to
// convert" note instead. Everything else shows the dated mid-market rate,
// refreshed daily from /api/rates with the baked snapshot as the fallback. A
// code with no rate anywhere hides itself cleanly.
const FX_PAR = ["USD", "BSD", "PAB"];
const FX_PAR_NOTE = {
  USD: "This country uses the US dollar, so prices are already in the currency you think in, and on a card terminal or ATM there is nothing to convert.",
  BSD: "The Bahamian dollar is pegged one to one with the US dollar and the two are used interchangeably, so prices are effectively in dollars. On a card terminal, still choose the local currency to dodge the poor conversion.",
  PAB: "Panama uses the US dollar as everyday cash alongside the balboa, which is fixed one to one, so prices are effectively in dollars and there is nothing to convert."
};
const fxCur = (c.cash && c.cash.cur) || "";
const fxFb = fxFallback.rates[fxCur];
const fxShowPanel = fxCur && !FX_PAR.includes(fxCur);
const fxShowPar = FX_PAR.includes(fxCur);
const fxRateForDefault = fxFb || 1;
const fxDefaultNum = fxRateForDefault >= 1000 ? 100000 : fxRateForDefault >= 100 ? 10000 : fxRateForDefault >= 10 ? 1000 : 100;
function fxFmtLocal(n) {
  if (!isFinite(n)) return "";
  return n >= 100 ? Math.round(n).toLocaleString("en-US") : (Math.round(n * 100) / 100).toString();
}
function fxFmtUsd(n) {
  if (!isFinite(n)) return "";
  return "$" + (n >= 1000 ? Math.round(n).toLocaleString("en-US") : (Math.round(n * 100) / 100).toFixed(2));
}
// One canonical commission label per pick, chosen only by whether its link is a
// real external URL. Never hand-typed into content, the same rule cards.js uses.
const commLabel = (url) => ext(url).target
  ? { cls: "tg earn", text: "we may earn a commission" }
  : { cls: "tg free", text: "we earn nothing" };
// The per-country "how much it matters" dial, built like the cash meter: the card
// content never changes, only this one sentence does, by c.insuranceLevel.
const insLevels = {
  low: "Here, good hospitals are easy to reach and the care is high quality, so for a healthy traveler this leans more toward your call than a must.",
  medium: "Care in the main cities is good, but costs add up and reaching top care from a remote spot takes time, so it is worth a real look for a trip here.",
  high: "Strong care can sit a long way from where you are traveling and an evacuation is a genuine possibility, so this is one to weigh seriously for a trip here."
};
const insLevel = insLevels[c.insuranceLevel] ? c.insuranceLevel : "medium";
const insDial = insLevels[insLevel];
// The one genuinely per-country fact on an otherwise global card: the local
// ambulance number, web-verified with its own checked date. May be null.
const emg = c.emergency || null;
// Section illustrations. One shared, generic set covers every country: an ATM for
// currency basics, a hotel bill for the real-cost calculator, a card terminal for
// the traps. No per-country image work is needed. A country may override any slot
// by setting c.art = { currency, cost, traps } with its own image path. On by default
// for every country; a country can opt out entirely with art:false, or override a
// single slot by passing an object.
const ART_DEFAULTS = { currency: "/art/atm-currency.jpg", cost: "/art/hotel-bill.jpg", traps: "/art/card-terminal.jpg" };
const art = (c.art === false) ? null : { ...ART_DEFAULTS, ...((c.art && typeof c.art === "object") ? c.art : {}) };
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": (c.faqs || []).map(f => ({
    "@type": "Question", "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
const artLd = {
  "@context": "https://schema.org", "@type": "Article",
  "headline": c.title, "description": c.description,
  "dateModified": c.checkedISO, "datePublished": c.checkedISO,
  "author": { "@type": "Organization", "name": "True Trip Costs" }
};
// keyFacts: the high-churn fees and taxes (the numbers that move on political
// timelines). Each item carries its own status, effective date, source and the
// date it was last checked, so the honest status lives with the fact itself
// rather than in one page-level stamp. A proposed item reads as not yet in effect;
// an item whose effective date is still in the future reads as upcoming; anything
// else reads as in effect. A missing source simply renders without a link.
const KF_MONTHS = ["January","February","March","April","May","June","July","August","September","October","November","December"];
const kfDate = (iso) => {
  if (!iso) return "";
  const d = new Date(iso + "T00:00:00Z");
  if (isNaN(d.getTime())) return "";
  return d.getUTCDate() + " " + KF_MONTHS[d.getUTCMonth()] + " " + d.getUTCFullYear();
};
const kfNow = new Date();
const kfState = (f) => {
  if (f.status === "proposed") return "proposed";
  if (f.effective) { const e = new Date(f.effective + "T00:00:00Z"); if (!isNaN(e.getTime()) && e > kfNow) return "upcoming"; }
  return "inEffect";
};
---
{c.blocked && (
  <section class="blocked">
    <div class="ctx">
      <span>Money briefing</span><span>&middot;</span><span><b style="color:var(--ink)">{c.from} &#8594; {c.name}</b></span>
    </div>
    <h2>We do not cover {c.name} right now.</h2>
    <p set:html={c.blockedNote || "We do not currently publish a money guide for this destination. When a place is under sanctions, off-limits, or the money facts cannot be verified to the standard we hold ourselves to, we would rather show nothing than guess."}></p>
    <p class="bback"><a href="/">Back to all money guides &#8594;</a></p>
  </section>
)}

{!c.blocked && (<Fragment>
<nav class="crumb" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="crumb-sep" aria-hidden="true">&#8250;</span>
  {regionHubLive && (<Fragment><a href={'/' + regionHub.slug}>{regionHub.label}</a><span class="crumb-sep" aria-hidden="true">&#8250;</span></Fragment>)}
  <span aria-current="page">{c.name}</span>
</nav>
<div class={"hero" + (c.hero && c.hero.img ? "" : " solo")}>
  <div class="hcopy">
    <div class="ctx">
      <span>Money briefing</span><span>&middot;</span>
      <span class="ctx-route"><b style="color:var(--ink)">{c.from}</b><span aria-hidden="true">&#8594;</span><span class="ds-wrap">
        <button type="button" class="ds-btn" id="dsBtn" aria-haspopup="listbox" aria-expanded="false" aria-label={"Change destination, currently " + c.name}><b style="color:var(--ink)">{c.name}</b><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="ds-panel" id="dsPanel" hidden>
          <div class="ds-search"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg><input type="text" id="dsSearch" placeholder="Switch country" aria-label="Search for a destination" autocomplete="off" /></div>
          <div class="ds-list" id="dsList" role="listbox">
            {jumpTargets.map(t => (<a class="ds-item" href={'/' + t.slug} data-n={t.name.toLowerCase()}>{t.name}</a>))}
          </div>
          <p class="ds-none" id="dsNone" hidden>No match. <a href="/">See all guides</a>.</p>
        </div>
      </span></span><span>&middot;</span>
      <span class="stamp"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#10502C" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>checked {c.checked}</span>
    </div>
    <h1>{c.h1}</h1>
    <p class="hlede">{c.lede}</p>
  </div>
  {c.hero && c.hero.img && (
    <div class="hart"><img src={c.hero.img} alt={c.hero.alt} width="1100" height={c.hero.h} /></div>
  )}
</div>

<div class="notice" id="notice" set:html={c.notice}></div>

<div class="verdict">
  <span class="vlead">The short version</span>
  <Fragment set:html={c.verdict} />
  <div class="vcta"><a class="btn light" href="#calc">Estimate your on-the-ground money costs
    <svg class="arw" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>
</div>

{c.recentChange && (
  <div class="recentchange">
    <span class="rcpill">Money update &middot; {c.recentChange.date}</span>
    <p set:html={c.recentChange.text}></p>
  </div>
)}

<section id="cards">
  <p class="lab">The three things people ask</p>
  <h2>Will my card work? Do I need cash? Are ATMs easy?</h2>
  <p class="sub">The quick read for a first trip.</p>
  <div class="trio">
    {c.trio.map(t => {
      const isAtm = t.sym === "atm";
      const href = isAtm ? atmMap : dest(t.cta);
      const attrs = isAtm ? ext(atmMap, false) : ext(dest(t.cta));
      const label = isAtm ? `See ATMs in ${c.name}` : t.cta.label;
      return (
      <div class={"vc " + t.kind}>
        <Symbol name={t.sym} cls="sym" />
        <div class="bd">
          <h3>{t.h}</h3>
          <p class="verd">{t.verd}</p>
          <p set:html={t.p}></p>
          <a class="cta" href={href} {...attrs}>{label} <span class="arw">&#8594;</span>{attrs.target && <NewTab />}</a>
        </div>
      </div>
      );
    })}
  </div>
</section>

<section id="cash">
  <p class="lab">Cash or card</p>
  <h2>{c.meter.heading}</h2>
  <div class="meter">
    <div class="meterhead">
      <span class="ml cash"><span class="mdot"></span>about {c.meter.cashPct}% cash</span>
      <span class="ml card"><span class="mdot"></span>{100 - c.meter.cashPct}% card</span>
    </div>
    <div class="meterbar" aria-hidden="true">
      <div class="cash" style={"width:" + c.meter.cashPct + "%"}></div>
      <div class="cardp" style={"width:" + (100 - c.meter.cashPct) + "%"}></div>
    </div>
    <p class="meternote">{c.meter.note}</p>
    <a class="cta" href="#calc">See what the trip really costs <span class="arw">&#8594;</span></a>
  </div>
</section>

<section>
  <p class="lab">Your money plan</p>
  <h2>Four steps and you're set.</h2>
  <div class="plan">
    {c.plan.map(p => (
      <div class="pstep">
        <Symbol name={p.sym} cls="psym" />
        <div class="pbody">
          <h3 class="pwhen">{p.when}</h3>
          <ul>{p.bullets.map(b => (<li set:html={b}></li>))}</ul>
          {p.cta && (
            <a class="cta" href={dest(p.cta)} {...ext(dest(p.cta))}>{p.cta.label}
              <span class={"tg " + p.cta.tag}>{p.cta.tag === "earn" ? "we may earn a commission" : "we earn nothing"}</span>
              <span class="arw">&#8594;</span>{ext(dest(p.cta)).target && <NewTab />}</a>
          )}
          {/* The old "Before you go" insurance line lived here. It now has its own
              Medical cover section after Staying connected, so there is one insurance
              moment on the page, not two. */}
        </div>
      </div>
    ))}
  </div>
</section>

{c.connectivity && (
<section>
  <p class="lab lab-ico-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 10.5a10.5 10.5 0 0 1 15 0"/><path d="M7.2 13.4a6.5 6.5 0 0 1 9.6 0"/><path d="M9.8 16.2a2.8 2.8 0 0 1 4.4 0"/><circle cx="12" cy="18.7" r="0.7" fill="currentColor" stroke="none"/></svg>Staying connected</p>
  <h2>Will my phone work here? And what will it cost?</h2>
  <p class="sub">{c.connectivity.works} The cost is where people get caught out, and on most US plans it lands in one of two buckets.</p>
  <div class="trio">
    <div class="vc ok">
      <Symbol name="phoneok" cls="sym" />
      <div class="bd">
        <h3>{(c.connectivity.covered && c.connectivity.covered.h) || "Your plan may already include it"}</h3>
        <p class="verd">{(c.connectivity.covered && c.connectivity.covered.verd) || "Often, do nothing"}</p>
        <p>{(c.connectivity.covered && c.connectivity.covered.p) || "Some US plans include slow data abroad at no extra cost. If that is you, the honest move is to leave it alone."}</p>
        <p style="margin-top:8px"><span class="tg free">we earn nothing</span></p>
      </div>
    </div>
    <div class="vc warn">
      <Symbol name="roamfee" cls="sym" />
      <div class="bd">
        <h3>{(c.connectivity.charged && c.connectivity.charged.h) || "Or it charges quietly, after the fact"}</h3>
        <p class="verd">{(c.connectivity.charged && c.connectivity.charged.verd) || "The bill lands later"}</p>
        <p>{(c.connectivity.charged && c.connectivity.charged.p) || "On pay-per-use plans the cost runs in the background while you travel, and the charge can show up weeks after you are home. Forgetting to switch off data roaming is the classic one. For a week or more, an eSIM is usually cheaper and keeps you in control."}</p>
      </div>
    </div>
  </div>
  <p style="font-size:14.5px;margin:16px 0 0">Check what your own carrier charges before the trip, not after.</p>
  {esim && (
    <Fragment>
      <p style="font-size:14.5px;margin:6px 0 0">If an eSIM is the cheaper call, {esimBrand ? `${esimBrand} covers ${c.name}.` : `there is a tracked eSIM option for ${c.name}.`}</p>
      <span class="pickcta">
        <a class="pickbtn" href={esim} {...ext(esim)}>{esimBrand ? `Get your ${esimBrand} eSIM for ${c.name}` : `Get an eSIM for ${c.name}`}<span class="arw">&#8594;</span>{ext(esim).target && <NewTab />}</a>
        <span class="tg earn">we may earn a commission</span>
      </span>
    </Fragment>
  )}
</section>
)}

<section id="insurance">
  <p class="lab">Medical cover</p>
  <div class="ins-head">
    <svg class="ins-motif" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#0E7A5F" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 12 7 12s7-7 7-12a7 7 0 0 0-7-7z"/><path d="M12 6v6M9 9h6"/></svg>
    <h2>The one cost with no price tag.</h2>
  </div>
  <p class="sub">Every other number on this page has a price you can look up. This one does not, and it can be the largest of them all. Most US health plans cover little or nothing once you leave the country, and Medicare covers essentially none of it abroad. A serious illness or injury is paid up front, and a medical evacuation runs from tens of thousands of dollars to past $100,000 if you are remote or an ocean from home.</p>

  <div class="ins">
    <div class="ins-skip">
