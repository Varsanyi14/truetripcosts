---
// A spoke: a short, focused page that answers ONE on-the-ground money question for a
// country, part of the hub-and-spoke model. It is deliberately much smaller than
// CountryBriefing. It renders from a single spoke data object (stored in the country's
// data file, so it stays single-source and independently dated) and is wrapped in the
// site chrome by src/pages/[slug]/[spoke].astro, exactly the way [slug].astro wraps
// CountryBriefing. Reuses the shared tokens and callout classes from global.css.
import { regionOf, REGIONS } from '../data/hubs.js';
const { country, spoke } = Astro.props;

const site = 'https://truetripcosts.com';

// Home > Region > Country > Spoke breadcrumb, mirrored as BreadcrumbList JSON-LD, the
// same chain the country page builds so the two stay consistent. The region step
// appears only once that region hub is live.
const region = regionOf(country);
const regionHub = region ? REGIONS[region] : null;
const regionHubLive = !!(regionHub && regionHub.live);
const crumbItems = [{ name: 'Home', url: site + '/' }];
if (regionHubLive) crumbItems.push({ name: regionHub.label, url: site + '/' + regionHub.slug });
crumbItems.push({ name: country.name, url: site + '/' + country.slug });
crumbItems.push({ name: spoke.h1, url: site + '/' + country.slug + '/' + spoke.slug });
const crumbLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: crumbItems.map((it, i) => ({ '@type': 'ListItem', position: i + 1, name: it.name, item: it.url })) };

// FAQ schema is built from the same faqs array the visible Q&As render from, so the
// two can never drift. Emitted only when the spoke actually has FAQs.
const faqLd = (spoke.faqs && spoke.faqs.length) ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: spoke.faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
} : null;

// Article schema, same shape and author the country pages use. Headline and dates come
// from the spoke's own fields, so each spoke carries its own checked date.
const artLd = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: spoke.title, description: spoke.description,
  dateModified: spoke.checkedISO, datePublished: spoke.checkedISO,
  author: { '@type': 'Organization', name: 'True Trip Costs' }
};

// Split a source label into a name (before the colon) and a short note (what it
// verifies), matching how the country guide lists its sources. Spokes are short, so
// they use one consistent source icon rather than the per-type icons on the guides.
function srcParts(s) {
  const i = s.label.indexOf(': ');
  return { name: i === -1 ? s.label : s.label.slice(0, i), note: i === -1 ? '' : s.label.slice(i + 2) };
}
const sections = Array.isArray(spoke.sections) ? spoke.sections : [];
const faqs = Array.isArray(spoke.faqs) ? spoke.faqs : [];
---

<article class="spoke">
  <p class="sp-parent"><a href={'/' + country.slug}>&#8592; Part of the {country.name} money guide</a></p>

  <div class="ctx"><span class="stamp"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#10502C" stroke-width="3" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>checked {spoke.checked}</span></div>

  <h1>{spoke.h1}</h1>
  {spoke.lede && <p class="sp-lede">{spoke.lede}</p>}

  {spoke.answer && (
    <div class="recentchange" style="margin-top:22px">
      <span class="rcpill">The short answer</span>
      <p set:html={spoke.answer}></p>
    </div>
  )}

  {sections.map(sec => (
    <section class="sp-sec">
      {sec.h && <h2>{sec.h}</h2>}
      {(sec.p || []).map(par => <p set:html={par}></p>)}
      {sec.steps && sec.steps.length > 0 && (
        <ol class="sp-steps">
          {sec.steps.map(st => <li set:html={st}></li>)}
        </ol>
      )}
    </section>
  ))}

  {faqs.length > 0 && (
    <section class="sp-sec">
      <p class="lab">Common questions</p>
      <h2>Quick answers.</h2>
      <div class="faq">
        {faqs.map(f => (<div class="faqitem"><h3>{f.q}</h3><p>{f.a}</p></div>))}
      </div>
    </section>
  )}

  <div class="sp-back">
    <a class="cta" href={'/' + country.slug}>Read the full {country.name} money guide &#8594;</a>
  </div>

  <div class="gbyline" style="display:flex;align-items:flex-start;gap:9px;margin:26px 0 0;padding:14px 16px;border:1px solid var(--line);border-radius:12px;background:var(--card)">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#0A5644" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:2px" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
    <p style="margin:0;font-size:13px;line-height:1.55;color:#5C6661">Written and kept current by the True Trip Costs desk. Last checked {spoke.checked}. <a href="/about" style="color:var(--teal-deep);font-weight:500;text-decoration:none">Who writes these, and how they are checked &#8594;</a></p>
  </div>

  {spoke.sources && (
    <details class="gsources">
      <summary class="gsources-sum">
        <span class="gsources-head">
          <svg class="gsources-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0A5644" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="gsources-txt">Sources, and how this was checked</span>
        </span>
        <svg class="gsources-chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </summary>
      <div class="gsources-body">
        <p class="gs-row"><span class="gs-k">Last checked</span><span>{spoke.checked}</span></p>
        {spoke.sources.links && spoke.sources.links.length > 0 && (
          <div class="gs-row"><span class="gs-k">Primary sources</span>
            <ul class="gs-links">
              {spoke.sources.links.map(s => { const m = srcParts(s); return (
                <li class="gs-src">
                  <span class="gs-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="m9 12 2 2 4-4"/></svg></span>
                  <span class="gs-src-tx">
                    <a href={s.url} target="_blank" rel="noopener" class="gs-src-name">{m.name}</a>
                    {m.note && <span class="gs-src-note">{m.note}</span>}
                  </span>
                </li>
              ); })}
            </ul>
          </div>
        )}
        {spoke.sources.judgment && <p class="gs-row"><span class="gs-k">Our own read</span><span>{spoke.sources.judgment}</span></p>}
      </div>
    </details>
  )}
</article>

<script type="application/ld+json" set:html={JSON.stringify(crumbLd)}></script>
{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)}></script>}
<script type="application/ld+json" set:html={JSON.stringify(artLd)}></script>

<style>
  .spoke{padding:8px 0 10px}
  .sp-parent{margin:22px 0 0;font-size:13px}
  .sp-parent a{color:var(--teal-deep);font-weight:600;text-decoration:none}
  .sp-parent a:hover{text-decoration:underline}
  .sp-lede{font-size:18px;color:#3B4A46;line-height:1.55;margin:0}
  .sp-sec{padding:26px 0 0;border-top:1px solid var(--line);margin-top:26px}
  .sp-sec h2{margin:0 0 10px}
  .sp-sec p{font-size:16px;color:#3B4A46;line-height:1.65;margin:0 0 14px}
  .sp-sec p:last-child{margin-bottom:0}
  .sp-steps{margin:6px 0 0;padding:0 0 0 2px;list-style:none;counter-reset:step}
  .sp-steps li{position:relative;padding:0 0 14px 40px;counter-increment:step;font-size:16px;color:#3B4A46;line-height:1.6}
  .sp-steps li:last-child{padding-bottom:0}
  .sp-steps li::before{content:counter(step);position:absolute;left:0;top:1px;width:26px;height:26px;border-radius:999px;background:var(--green-bg);color:var(--teal-deep);font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center}
  .sp-back{margin-top:26px}
  .gs-ic{flex:none;color:var(--muted);display:inline-flex;margin-top:1px}
  @media (max-width:560px){
    .sp-lede{font-size:16.5px}
    .sp-sec p,.sp-steps li{font-size:15.5px}
  }
</style>
