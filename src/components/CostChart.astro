---
// Reusable ranked, stacked cost-comparison bar chart.
//
// Reads live country data passed in by the caller. Nothing here is hardcoded:
// the bars, order, totals and the client-side tier payload are all derived from
// the `countries` prop at build time, so adding a country or changing a figure
// in the data updates this chart on the next build.
//
// Each country contributes cash.styles: an array of three tiers
//   { n: 'Budget'|'Mid-range'|'Comfort', per: <number>, room: <number> }
// TOTAL for a tier = per + room (a typical day including a room).
//
// The component server-renders the default tier (so the page is correct and
// readable with no JS), and embeds a compact per-tier payload that the page's
// script uses to recompute, re-sort and animate when the tier changes.

const {
  countries = [],
  defaultTier = 'Mid-range',
  tiers = ['Budget', 'Mid-range', 'Comfort'],
  id = 'costchart',
} = Astro.props;

const tierOf = (c, name) => (c.cash && c.cash.styles || []).find(s => s.n === name);

// Build a clean, self-contained model for every tier: for each country, its
// per/room/total under that tier. This is the single source the client reuses.
function modelForTier(name) {
  return countries
    .map(c => {
      const t = tierOf(c, name);
      if (!t || typeof t.per !== 'number' || typeof t.room !== 'number') return null;
      return { slug: c.slug, name: c.name, region: c.region, per: t.per, room: t.room, total: t.per + t.room };
    })
    .filter(Boolean)
    .sort((a, b) => a.total - b.total);
}

const payload = {};
for (const name of tiers) payload[name] = modelForTier(name);

const initial = payload[defaultTier] || [];

// Axis scale is PER TIER. A single shared max (scaled to the priciest tier) left
// the cheaper tiers squeezed into a sliver of the width, which on a phone made
// the bars unreadable. Each tier now maxes at its own highest total, so bars fill
// the width. To keep that honest the axis maximum is labeled on every tier and
// the dollar figure stays on every bar, which is the real source of truth
// regardless of how the axis is scaled.
function niceMax(v) {
  if (!v) return 0;
  // Round up to a tidy step so the axis reads cleanly: 220 -> 300, 470 -> 500.
  const step = v <= 300 ? 50 : 100;
  return Math.ceil(v / step) * step;
}
// Pick a tick step that yields roughly `want` ticks, from a tidy ladder, so the
// labels never crowd. Mobile asks for fewer.
function tickStep(max, want) {
  const ladder = [25, 50, 100, 150, 200, 250, 500, 1000];
  for (const s of ladder) if (max / s <= want) return s;
  return ladder[ladder.length - 1];
}
function ticksFor(max, want) {
  const s = tickStep(max, want);
  const out = [];
  for (let v = 0; v <= max; v += s) out.push(v);
  // Close the axis on its true maximum, but replace rather than append when that
  // label would crowd the previous tick.
  const lastTick = out[out.length - 1];
  if (lastTick !== max) {
    if ((max - lastTick) / s < 0.45) out[out.length - 1] = max;
    else out.push(max);
  }
  return out;
}

const axisMaxByTier = {};
for (const name of tiers) {
  const rows = payload[name];
  axisMaxByTier[name] = niceMax(rows.length ? Math.max(...rows.map(r => r.total)) : 0);
}
const axisMax = axisMaxByTier[defaultTier] || 0;
// Desktop gets a denser axis; the client swaps to the mobile tick count at narrow
// widths. Both are generated from the same tidy ladder.
const ticks = ticksFor(axisMax, 7);

const pct = v => (axisMax ? (v / axisMax) * 100 : 0);
---

<div
  class="cc"
  id={id}
  data-scalemax={axisMax}
  data-tier={defaultTier}
  data-axismax={JSON.stringify(axisMaxByTier)}
>
  <div class="cc-toolbar" role="group" aria-label="Choose a travel style">
    {tiers.map(name => (
      <button
        type="button"
        class:list={["cc-tier", { 'is-active': name === defaultTier }]}
        data-tier-btn={name}
        aria-pressed={name === defaultTier ? 'true' : 'false'}
      >{name}</button>
    ))}
  </div>

  <p class="cc-scale">
    Scale runs to <span class="cc-scalemax">${axisMax}</span> a day for this travel style.
    Each style is scaled to its own range, so compare the dollar figures, not bar lengths, across styles.
  </p>

  <div class="cc-axis" aria-hidden="true">
    {ticks.map(v => (
      <span class="cc-tick" style={`left:${pct(v)}%`}><em>${v}</em></span>
    ))}
  </div>

  <ol class="cc-list" id={`${id}-list`}>
    <span class="cc-gridlayer" aria-hidden="true">
      {ticks.map(v => (
        <span class="cc-grid" style={`left:${pct(v)}%`}></span>
      ))}
    </span>
    {initial.map((row, i) => (
      <li class="cc-row" data-slug={row.slug} style={`--rank:${i}`}>
        <a class="cc-name" href={`/${row.slug}`}>{row.name}</a>
        <span class="cc-track">
          <span class="cc-bar">
            <span class="cc-seg cc-room" style={`width:${pct(row.room)}%`}
              title={`Room: $${row.room}`}></span>
            <span class="cc-seg cc-per" style={`width:${pct(row.per)}%`}
              title={`On the ground: $${row.per}`}></span>
          </span>
          <span class="cc-total num">${row.total}</span>
        </span>
      </li>
    ))}
  </ol>

  <p class="cc-legend" aria-hidden="true">
    <span class="cc-key cc-room"></span> Room
    <span class="cc-key cc-per"></span> On the ground (food, local transport, activities)
    <span class="cc-hint">Full bar length is the typical daily total.</span>
  </p>

  <script type="application/json" data-cc-payload={id} set:html={JSON.stringify(payload)} />
</div>

<style>
  .cc{--room:#0A5644;--per:#9CC7B6;margin:0}
  .cc-toolbar{display:inline-flex;gap:4px;padding:4px;background:var(--card);border:1px solid var(--line);border-radius:999px;margin:0 0 22px;box-shadow:var(--shadow)}
  .cc-tier{font:inherit;font-size:13.5px;font-weight:600;color:var(--muted);background:transparent;border:0;border-radius:999px;padding:7px 16px;cursor:pointer;transition:color .18s ease,background .18s ease,box-shadow .18s ease}
  .cc-tier:hover{color:var(--amber)}
  .cc-tier.is-active{color:#fff;background:var(--amber);box-shadow:0 1px 2px rgba(180,83,9,.25)}

  /* Quiet axis: thin ticks, no heavy gridlines. */
  .cc-axis{position:relative;height:18px;margin-left:clamp(88px,22%,150px)}
  .cc-tick{position:absolute;top:0;transform:translateX(-50%);font-size:11px;color:var(--muted)}
  .cc-tick em{font-style:normal;font-variant-numeric:tabular-nums}

  /* Gridlines are drawn inside the bar list and clipped to it, so they stop at
     the bottom of the last bar instead of running down the whole page. The layer
     overlays exactly the bar column (left edge at the name column), and each line
     is positioned by the same left:% the axis ticks use. */
  .cc-list{list-style:none;margin:6px 0 0;padding:0;position:relative;overflow:hidden}
  .cc-gridlayer{position:absolute;top:0;bottom:0;left:clamp(88px,22%,150px);right:calc(52px + 10px);pointer-events:none}
  .cc-grid{position:absolute;top:0;bottom:0;width:1px;background:var(--line);opacity:.5;transform:translateX(-50%)}
  .cc-row{display:grid;grid-template-columns:clamp(88px,22%,150px) 1fr;align-items:center;gap:0;padding:5px 0;will-change:transform}
  .cc-name{font-size:13.5px;font-weight:600;color:var(--ink);text-decoration:none;padding-right:12px;text-align:right;line-height:1.2;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .cc-name:hover{color:var(--teal-deep);text-decoration:underline}
  .cc-track{display:flex;align-items:center;gap:10px;min-width:0}
  .cc-bar{position:relative;display:flex;height:15px;border-radius:5px;overflow:hidden;flex:1;min-width:0;background:transparent}
  .cc-seg{height:100%;transition:width .5s cubic-bezier(.22,.61,.36,1)}
  .cc-seg.cc-room{background:var(--room)}
  .cc-seg.cc-per{background:var(--per)}
  .cc-total{flex:0 0 auto;font-family:var(--serif);font-size:15px;color:var(--ink);min-width:52px;font-variant-numeric:tabular-nums}

  .cc-legend{display:flex;align-items:center;flex-wrap:wrap;gap:8px;font-size:12.5px;color:var(--muted);margin:20px 0 0}
  .cc-key{width:12px;height:12px;border-radius:3px;display:inline-block}
  .cc-key.cc-room{background:var(--room)}
  .cc-key.cc-per{background:var(--per);margin-left:8px}
  .cc-hint{flex-basis:100%;color:var(--muted)}

  .cc-scale{font-size:12.5px;color:var(--muted);margin:0 0 10px;line-height:1.45}
  .cc-scalemax{font-weight:700;color:var(--ink);font-variant-numeric:tabular-nums}

  /* On a phone there is no room for a side label column wide enough for names
     like "Dominican Republic", so the name moves above its own bar. That kills
     the truncation and hands the full width to the bar. */
  @media (max-width:560px){
    .cc-axis{margin-left:0}
    .cc-gridlayer{left:0;right:calc(46px + 10px)}
    .cc-row{display:block;padding:8px 0}
    .cc-name{display:block;text-align:left;padding-right:0;white-space:normal;overflow:visible;text-overflow:clip;margin:0 0 4px;font-size:13px}
    .cc-total{min-width:46px;font-size:14px}
  }
  @media (prefers-reduced-motion: reduce){
    .cc-seg{transition:none}
  }
</style>
