---
// The tipping ramp: the page's hook, and the whole lesson in one shape.
//
// A horizontal scale runs from "leave nothing" on the left to the US habit on
// the right. Each of the five tiers is a block whose WIDTH is proportional to
// how many countries sit in it, so the distribution is the picture: a reader
// sees that the mass sits left of home before reading a single word.
//
// Reads the rows passed in (live data, nothing hardcoded).

const {
  rows = [],
  baseline = null,
  tiers = ['Not customary', 'Round up only', 'Small optional', 'Modest customary', 'Expected / standard'],
  id = 'tipramp',
} = Astro.props;

// Short label and the money line for each tier, so a block says what it costs.
const SHORT = {
  'Not customary': 'Tip nothing',
  'Round up only': 'Round up',
  'Small optional': 'A little',
  'Modest customary': 'About 10%',
  'Expected / standard': 'US level',
};
const MONEY = {
  'Not customary': '0%',
  'Round up only': 'coins',
  'Small optional': '5 to 10%',
  'Modest customary': '10%',
  'Expected / standard': '15 to 20%',
};

const total = rows.length || 1;
const bands = tiers.map((t, i) => {
  const list = rows.filter(r => r.tier === t);
  return {
    tier: t,
    rank: i,
    short: SHORT[t] || t,
    money: MONEY[t] || '',
    n: list.length,
    pct: (list.length / total) * 100,
    isUs: baseline ? t === baseline.tier : false,
  };
}).filter(b => b.n > 0);
---

<div class="rmp" id={id}>
  <div class="rmp-scale" role="img" aria-label={`Distribution of ${total} countries across five tipping tiers, from tip nothing to US level`}>
    {bands.map(b => (
      <div class:list={["rmp-seg", `r${b.rank}`, { 'is-us': b.isUs }]} style={`flex-grow:${b.n}`}>
        <span class="rmp-n">{b.n}</span>
        <span class="rmp-short">{b.short}</span>
        <span class="rmp-money">{b.money}</span>
      </div>
    ))}
  </div>

  <div class="rmp-axis" aria-hidden="true">
    <span>Leave nothing</span>
    <span class="rmp-axis-line"></span>
    <span class="rmp-here">Your home habit</span>
  </div>

  {baseline && (
    <p class="rmp-read">
      Only <strong>{bands.filter(b => b.isUs).reduce((a, b) => a + b.n, 0)} of {total}</strong> countries
      expect anything like the <strong>{baseline.restaurant}</strong> you leave at home.
      <strong> {rows.filter(r => r.tierRank === 0).length}</strong> expect nothing at all.
    </p>
  )}
</div>

<style>
  .rmp{margin:0 0 8px}
  .rmp-scale{display:flex;gap:3px;align-items:stretch;min-height:104px}
  .rmp-seg{flex:1 1 0;min-width:0;border-radius:10px;padding:12px 10px;display:flex;flex-direction:column;justify-content:flex-start;gap:2px;overflow:hidden}
  /* Single hue deepening left to right: the ramp IS the encoding. */
  .rmp-seg.r0{background:rgba(10,86,68,.10)}
  .rmp-seg.r1{background:rgba(10,86,68,.20)}
  .rmp-seg.r2{background:rgba(10,86,68,.34)}
  .rmp-seg.r3{background:rgba(10,86,68,.52)}
  .rmp-seg.r4{background:var(--amber);}
  .rmp-seg.r3 .rmp-n,.rmp-seg.r3 .rmp-short,.rmp-seg.r3 .rmp-money,
  .rmp-seg.r4 .rmp-n,.rmp-seg.r4 .rmp-short,.rmp-seg.r4 .rmp-money{color:#fff}
  .rmp-n{font-family:var(--serif);font-size:26px;line-height:1;color:var(--ink)}
  .rmp-short{font-size:12.5px;font-weight:700;color:var(--ink);line-height:1.25}
  .rmp-money{font-size:11.5px;color:var(--ink);opacity:.8;line-height:1.2}

  .rmp-axis{display:flex;align-items:center;gap:10px;margin:8px 0 0;font-size:11.5px;color:var(--muted)}
  .rmp-axis-line{flex:1;height:1px;background:var(--line)}
  .rmp-here{font-weight:700;color:var(--amber)}

  .rmp-read{font-size:15px;color:var(--ink);line-height:1.5;margin:14px 0 0;max-width:620px}
  .rmp-read strong{font-weight:700}

  @media (max-width:560px){
    .rmp-scale{min-height:96px;gap:2px}
    .rmp-seg{padding:9px 6px;border-radius:8px}
    .rmp-n{font-size:20px}
    .rmp-short{font-size:11px}
    .rmp-money{font-size:10.5px}
    .rmp-read{font-size:14.5px}
  }
</style>
