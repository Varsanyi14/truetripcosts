---
// Tier bands for the tipping page: the five customary-tipping tiers laid out
// lightest to heaviest, with the US baseline pinned as the yardstick.
//
// The whole point of this component is the comparison. A US traveler already
// knows what they tip at home, so every band is positioned relative to that
// anchor, and the band the US sits in is marked. Reading down the bands answers
// "how far from my instincts is this place" without any interaction.
//
// Reads the rows passed in (live data, nothing hardcoded). Confidence is shown
// per country chip, always on, using the same solid / soft / provisional
// language as RankChart.astro on the outbound page.

const {
  rows = [],
  baseline = null,
  tiers = ['Not customary', 'Round up only', 'Small optional', 'Modest customary', 'Expected / standard'],
  id = 'tiptiers',
} = Astro.props;

// Short, plain-language gloss for each tier. These describe the norm, not a rule.
const GLOSS = {
  'Not customary': 'Leave nothing. Tipping is not part of the culture, and in a few places it can land awkwardly.',
  'Round up only': 'Round the bill up or leave small coins. Service is typically already in the price.',
  'Small optional': 'A little is welcome, roughly 5 to 10 percent, but nobody is counting.',
  'Modest customary': 'Around 10 percent is the normal gesture, more in tourist-facing places.',
  'Expected / standard': 'Close to US habits. Staff may depend on tips, so budget a real line item.',
};

const byTier = {};
for (const t of tiers) byTier[t] = rows.filter(r => r.tier === t);

const baselineTier = baseline ? baseline.tier : null;
const total = rows.length;
const confClass = c => 'is-' + String(c || '').toLowerCase();
---

<div class="tt" id={id}>
  {baseline && (
    <div class="tt-anchor">
      <p class="tt-anchor-lab">Your yardstick</p>
      <p class="tt-anchor-body">
        At home in the <strong>{baseline.country}</strong> you tip <strong>{baseline.restaurant}</strong> at
        a restaurant. That is the habit you are travelling with. Here is where everywhere else sits.
      </p>
    </div>
  )}

  <ol class="tt-bands">
    {tiers.map((t, i) => {
      const list = byTier[t] || [];
      const isUs = t === baselineTier;
      return (
        <li class:list={["tt-band", `tt-r${i}`, { 'is-us': isUs }]}>
          <div class="tt-head">
            <span class="tt-tier">{t}</span>
            <span class="tt-n">{list.length} of {total}</span>
            {isUs && <span class="tt-usflag">US level</span>}
          </div>
          <p class="tt-gloss">{GLOSS[t]}</p>
          <ul class="tt-chips">
            {list.map(r => (
              <li class:list={["tt-chip", confClass(r.confidence)]} title={`${r.country}: ${r.restaurant}`}>
                {r.hasGuide
                  ? <a href={`/${r.slug}`}>{r.country}</a>
                  : <span>{r.country}</span>}
              </li>
            ))}
          </ul>
        </li>
      );
    })}
  </ol>

  <p class="tt-key" aria-hidden="true">
    <span class="tt-kc is-high"></span> firmer sourcing
    <span class="tt-kc is-medium"></span> less certain
    <span class="tt-kc is-low"></span> thin sourcing
  </p>
</div>

<style>
  .tt{margin:0}
  .tt-anchor{background:var(--amber-bg);border:1px solid var(--amber);border-radius:12px;padding:13px 16px;margin:0 0 18px;max-width:640px}
  .tt-anchor-lab{font-size:11.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--amber);margin:0 0 4px}
  .tt-anchor-body{font-size:15px;color:var(--ink);line-height:1.5;margin:0}

  .tt-bands{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px}
  .tt-band{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:13px 15px}
  /* A quiet left edge that deepens as the expectation rises, so the ramp from
     "leave nothing" to "US level" is visible at a glance. Single hue on purpose. */
  .tt-band.tt-r0{border-left:4px solid rgba(10,86,68,.16)}
  .tt-band.tt-r1{border-left:4px solid rgba(10,86,68,.32)}
  .tt-band.tt-r2{border-left:4px solid rgba(10,86,68,.48)}
  .tt-band.tt-r3{border-left:4px solid rgba(10,86,68,.68)}
  .tt-band.tt-r4{border-left:4px solid rgba(10,86,68,.92)}
  .tt-band.is-us{background:var(--amber-bg);border-color:var(--amber)}

  .tt-head{display:flex;align-items:center;flex-wrap:wrap;gap:9px;margin:0 0 4px}
  .tt-tier{font-weight:700;font-size:15px;color:var(--ink)}
  .tt-n{font-size:12px;color:var(--muted);font-variant-numeric:tabular-nums}
  .tt-usflag{font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff;background:var(--amber);border-radius:999px;padding:2px 8px}

  .tt-gloss{font-size:13.5px;color:var(--muted);line-height:1.5;margin:0 0 9px;max-width:620px}

  .tt-chips{list-style:none;margin:0;padding:0;display:flex;flex-wrap:wrap;gap:6px}
  .tt-chip{font-size:13px;border:1px solid var(--line);background:var(--paper);border-radius:999px;padding:4px 10px;line-height:1.3}
  .tt-chip a{color:var(--ink);text-decoration:none}
  .tt-chip a:hover{color:var(--teal-deep);text-decoration:underline}
  .tt-chip span{color:var(--ink)}
  /* Always-on confidence, matching the outbound page's language: solid edge for
     firmer rows, softer for medium, dashed/provisional for thin sourcing. */
  .tt-chip.is-high{border-color:rgba(10,86,68,.45)}
  .tt-chip.is-medium{border-color:var(--line);opacity:.88}
  .tt-chip.is-low{border-style:dashed;border-color:rgba(14,122,95,.55);opacity:.8}

  .tt-key{display:flex;align-items:center;flex-wrap:wrap;gap:7px;font-size:12px;color:var(--muted);margin:14px 0 0}
  .tt-kc{width:13px;height:13px;border-radius:999px;display:inline-block;border:1px solid var(--line);background:var(--paper)}
  .tt-kc.is-high{border-color:rgba(10,86,68,.45)}
  .tt-kc.is-medium{opacity:.88}
  .tt-kc.is-low{border-style:dashed;border-color:rgba(14,122,95,.55);opacity:.8}

  @media (max-width:560px){
    .tt-band{padding:12px 13px}
    .tt-tier{font-size:14.5px}
    .tt-gloss{font-size:13px}
    .tt-chip{font-size:12.5px}
  }
</style>
