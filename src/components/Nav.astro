---
---
<nav>
  <div class="wrap navin">
    <a class="logo" href="/" style="text-decoration:none;color:inherit">
      <svg width="30" height="30" viewBox="0 0 120 84" aria-hidden="true"><path d="M16 38 C5 34 7 21 20 22" fill="none" stroke="#0E7A5F" stroke-width="3.4" stroke-linecap="round"/><path d="M46 10 H90 a11 11 0 0 1 11 11 V51 a11 11 0 0 1 -11 11 H46 L14 37 Z" fill="#16302C"/><circle cx="32" cy="37" r="6.2" fill="#F5F4EF"/><text x="67" y="48" text-anchor="middle" font-family="Inter,Arial,sans-serif" font-weight="700" font-size="30" fill="#fff">$</text><path d="M95 49 L107 52.5 V62 C107 70.5 95 75 95 75 C95 75 83 70.5 83 62 V52.5 Z" fill="#0E7A5F"/><path d="M89.5 61.5l3.8 3.8 6.4-7" fill="none" stroke="#fff" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>True Trip Costs<small>The money side of travel</small></span>
    </a>
    <div class="navlinks">
      <details class="gmenu">
        <summary class="gmenu-sum">Guides<svg class="gmenu-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg></summary>
        <div class="gmenu-panel">
          <a href="/#guides">All country guides</a>
          <a href="/tourist-taxes">Tourist taxes and fees</a>
          <a href="/cash-or-card">Cash or card</a>
        </div>
      </details>
      <a class="navcta" href="#" data-open-signup>Get updates</a>
    </div>
  </div>

  <style>
    .navlinks{display:flex;align-items:center;gap:16px}
    .gmenu{position:relative}
    .gmenu-sum{display:inline-flex;align-items:center;gap:5px;font-size:14px;font-weight:500;color:var(--ink);cursor:pointer;list-style:none;white-space:nowrap}
    .gmenu-sum::-webkit-details-marker{display:none}
    .gmenu-sum:hover{color:var(--teal-deep)}
    .gmenu-chev{transition:transform .15s ease}
    .gmenu[open] .gmenu-chev{transform:rotate(180deg)}
    .gmenu-panel{position:absolute;top:calc(100% + 8px);right:0;min-width:210px;background:var(--card);border:1px solid var(--line);border-radius:12px;box-shadow:var(--shadow);padding:6px;z-index:60}
    .gmenu-panel a{display:block;padding:9px 11px;border-radius:8px;font-size:14px;color:var(--ink);text-decoration:none;white-space:nowrap}
    .gmenu-panel a:hover{background:var(--paper);color:var(--teal-deep)}
  </style>
</nav>

<script>
  (function () {
    var menus = document.querySelectorAll('details.gmenu');
    if (!menus.length) return;
    // Close an open menu when clicking anywhere outside it.
    document.addEventListener('click', function (e) {
      menus.forEach(function (m) { if (m.open && !m.contains(e.target)) m.open = false; });
    });
    // Close on Escape.
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') menus.forEach(function (m) { m.open = false; });
    });
    // Close after choosing an item, which matters for same-page anchors like /#guides.
    menus.forEach(function (m) {
      m.querySelectorAll('.gmenu-panel a').forEach(function (a) {
        a.addEventListener('click', function () { m.open = false; });
      });
    });
  })();
</script>
