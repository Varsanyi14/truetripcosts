---
import fs from 'fs';

// The tipping range chart: one row per country, sorted lightest to heaviest.
//
// Each row is a horizontal bar spanning that country's usual restaurant tip,
// drawn against an axis that ENDS at the top of the US habit. The US band
// occupies the final stretch of the axis, so a reader sees at a glance that
// home is the ceiling and almost everywhere expects less.
//
// Countries where nothing is expected get a "no tip" marker at the zero
// position rather than an invisible zero-length bar.
//
// Reads the rows passed in (live data). Percentages are parsed from the data's
// own addsPercent field, never re-typed.

const { rows = [], baseline = null, id = 'tipchart' } = Astro.props;

// Flag per country, matching the homepage and the cash-or-card page.
const flagDir = process.cwd() + '/public/flags/';
const flagSrc = (slug) => fs.existsSync(flagDir + slug + '.svg') ? '/flags/' + slug + '.svg' : '/flags/world.svg';

// Turn the data's addsPercent strings into a numeric low/high pair.
// Handles "0", "5 to 10", and "10 plus 5 to 10" (a charge plus extra on top).
function parseRange(a) {
  const s = String(a == null ? '' : a).trim();
  let m = s.match(/^(\d+)\s*to\s*(\d+)$/);
  if (m) return [Number(m[1]), Number(m[2])];
  m = s.match(/^(\d+)\s*plus\s*(?:optional\s*)?(\d+)\s*to\s*(\d+)$/);
  if (m) return [Number(m[1]), Number(m[1]) + Number(m[3])];
  m = s.match(/^(\d+)$/);
  if (m) return [Number(m[1]), Number(m[1])];
  return null;
}

const parsed = rows
  .map(r => {
    const range = parseRange(r.addsPercent);
    if (!range) return null;
    return { ...r, lo: range[0], hi: range[1] };
  })
  .filter(Boolean)
  .sort((a, b) => a.lo - b.lo || a.hi - b.hi || a.country.localeCompare(b.country));

// The axis runs from zero to the top of the US habit, which is also the highest
// figure anywhere in the data. Nothing can overflow it.
const usRange = baseline ? parseRange(baseline.addsPercent) : null;
const dataMax = parsed.length ? Math.max(...parsed.map(r => r.hi)) : 0;
const axisMax = Math.max(dataMax, usRange ? usRange[1] : 0) || 20;
const usLo = usRange ? usRange[0] : null;
const usHi = usRange ? usRange[1] : null;

const pct = v => (axisMax ? (v / axisMax) * 100 : 0);
const ticks = [];
for (let v = 0; v <= axisMax; v += 5) ticks.push(v);

const label = r => (r.lo === r.hi ? `${r.lo}%` : `${r.lo} to ${r.hi}%`);
---

<div class="tc" id={id} data-axismax={axisMax}>
  {usLo != null && (
    <p class="tc-key">
      <span class="tc-key-band"></span>
      What you tip at home, {usLo} to {usHi}%. Nowhere expects more.
    </p>
  )}

  <p class="tc-srckey">
    Most figures are firmly sourced and carry no mark. A faint dot means the
    sourcing is less firm, and a dashed bar means sources genuinely disagreed, so
    read it as an estimate.
  </p>

  <ol class="tc-rows" id={`${id}-rows`}>
    {parsed.map(r => (
      <li class="tc-row" data-slug={r.slug} data-name={r.country.toLowerCase()}>
        <span class="tc-country">
          <img class="tc-flag" src={flagSrc(r.slug)} alt="" width="22" height="16" loading="lazy" />
          {r.hasGuide
            ? <a href={`/${r.slug}`}>{r.country}</a>
            : <span>{r.country}</span>}
        </span>

        <span class="tc-plot">
          {usLo != null && (
            <span class="tc-band" style={`left:${pct(usLo)}%;right:0`} aria-hidden="true"></span>
          )}
          {ticks.map(v => (
            <span class="tc-grid" style={`left:${pct(v)}%`} aria-hidden="true"></span>
          ))}

          {r.hi === 0 ? (
            <span class:list={["tc-none", `conf-${r.confidence}`]} style={`left:${pct(0)}%`} title="Nothing expected">
              <svg viewBox="0 0 20 20" width="17" height="17" aria-hidden="true">
                <circle cx="10" cy="10" r="8" class="tc-none-disc" />
                <circle cx="10" cy="10" r="8" class="tc-none-ring" />
                <line x1="4.3" y1="15.7" x2="15.7" y2="4.3" class="tc-none-slash" />
              </svg>
            </span>
          ) : (
            <span
              class:list={["tc-bar", `conf-${r.confidence}`, { 'in-band': usLo != null && r.hi >= usLo }]}
              style={`left:${pct(r.lo)}%;width:${Math.max(1.5, pct(r.hi) - pct(r.lo))}%`}
            ></span>
          )}
        </span>

        <span class:list={["tc-val", `conf-${r.confidence}`]}>
          {r.hi === 0 ? 'nothing' : label(r)}
          {r.confidence === 'medium' && (
            <span class="tc-mark" title="Sourced, but less firm than most rows" aria-label="less firmly sourced">&#8226;</span>
          )}
          {r.confidence === 'low' && (
            <span class="tc-mark is-low" title="Sources disagree; treat this as an estimate" aria-label="provisional estimate">&#8226;</span>
          )}
        </span>
      </li>
    ))}
  </ol>

  <div class="tc-axis" aria-hidden="true">
    <span class="tc-axis-spacer"></span>
    <span class="tc-axis-track">
      <span class="tc-axis-line"></span>
      {ticks.map(v => (
        <span class="tc-tick" style={`left:${pct(v)}%`}>{v}%</span>
      ))}
    </span>
    <span class="tc-axis-spacer-r"></span>
  </div>

  <p class="tc-empty" id={`${id}-empty`} hidden>No country by that name. Check the spelling, or clear the box to see all of them.</p>
</div>

<style>
  .tc{--lab:200px;--val:82px;margin:0}
  .tc-key{display:flex;align-items:center;gap:8px;font-size:12.5px;color:var(--muted);margin:0 0 12px}
  .tc-key-band{width:26px;height:13px;border-radius:3px;background:rgba(180,83,9,.16);border:1px solid rgba(180,83,9,.4);flex:none}
  .tc-srckey{font-size:12px;color:var(--muted);line-height:1.5;margin:0 0 14px;max-width:620px}

  .tc-rows{list-style:none;margin:0;padding:0}
  .tc-row{display:grid;grid-template-columns:var(--lab) minmax(90px,1fr) var(--val);align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--line)}
  .tc-row.is-hidden{display:none}

  .tc-country{display:flex;align-items:center;gap:7px;min-width:0;max-width:var(--lab);font-size:13.5px;font-weight:600}
  .tc-flag{width:22px;height:16px;border-radius:3px;border:1px solid var(--line);object-fit:cover;display:block;flex:none}
  .tc-country a{color:var(--ink);text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .tc-country a:hover{color:var(--teal-deep);text-decoration:underline}
  .tc-country span{color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

  .tc-plot{position:relative;height:19px;min-width:0}
  /* The US habit occupies the last stretch of the axis, so home reads as the
     ceiling rather than a midpoint. */
  .tc-band{position:absolute;top:0;bottom:0;background:rgba(180,83,9,.10);border-left:1px dashed rgba(180,83,9,.45)}
  .tc-grid{position:absolute;top:0;bottom:0;width:1px;background:var(--line);opacity:.55}

  .tc-bar{position:absolute;top:3px;height:13px;border-radius:7px;background:var(--teal);opacity:.72;min-width:6px}
  .tc-bar.in-band{background:var(--amber);opacity:1}
  /* Low confidence reads as provisional: an outline rather than a solid fill, so
     it is visibly less settled than its neighbours without shouting. Only one row
     (Laos) currently qualifies. */
  .tc-bar.conf-low{background:transparent;border:1.5px dashed var(--teal);opacity:.9}
  .tc-bar.conf-low.in-band{background:transparent;border-color:var(--amber)}

  .tc-none{position:absolute;top:1px;display:inline-flex;line-height:0}
  .tc-none-disc{fill:rgba(14,122,95,.13)}
  .tc-none-ring{fill:none;stroke:var(--teal);stroke-width:1.5}
  .tc-none-slash{stroke:var(--teal);stroke-width:1.5;stroke-linecap:round}

  .tc-val{font-size:12.5px;color:var(--muted);text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap}
  /* Medium confidence gets one faint dot in the value column, never on the bar,
     so marking 28 of 53 rows stays quiet and cannot crowd the row on a phone.
     High confidence gets nothing: absence is the signal. */
  .tc-mark{color:var(--muted);opacity:.5;margin-left:3px;font-size:14px;line-height:1;cursor:help}
  .tc-mark.is-low{opacity:.85;color:var(--teal)}

  /* The axis shares the row's exact 3-column grid, so its middle cell is the same
     track as every .tc-plot. That guarantees pct(15) on the axis sits directly
     under pct(15) in the bars and the band, at every breakpoint. */
  .tc-axis{display:grid;grid-template-columns:var(--lab) minmax(90px,1fr) var(--val);gap:10px;margin:8px 0 0;padding-bottom:4px}
  .tc-axis-spacer{min-width:0}
  .tc-axis-track{position:relative;height:20px;min-width:0}
  .tc-axis-line{position:absolute;top:0;left:0;right:0;height:1px;background:var(--line)}
  .tc-tick{position:absolute;top:5px;transform:translateX(-50%);font-size:11px;color:var(--muted);font-variant-numeric:tabular-nums;white-space:nowrap}

  .tc-empty{font-size:14px;color:var(--muted);background:var(--card);border:1px solid var(--line);border-radius:12px;padding:14px;margin:14px 0 0}
  .tc-empty[hidden]{display:none}

  @media (max-width:640px){
    .tc{--lab:190px;--val:76px}
    .tc-row{gap:8px;padding:6px 0}
    .tc-country{font-size:12.5px;gap:6px}
    .tc-flag{width:19px;height:14px}
    .tc-val{font-size:11.5px}
    .tc-tick{font-size:10.5px}
  }
  /* Under ~430px there is no honest way to fit a name column, a plot and a value
     on one line, so the country moves above its own bar at full width. Names stop
     truncating and the bar gets the whole row. */
  @media (max-width:430px){
    .tc-row{grid-template-columns:1fr var(--val);grid-template-areas:"name name" "plot value";gap:4px 8px;padding:8px 0}
    .tc-country{grid-area:name;font-size:13px;white-space:normal}
    .tc-country a,.tc-country span{white-space:normal;overflow:visible;text-overflow:clip}
    .tc-plot{grid-area:plot}
    .tc-val{grid-area:value}
    /* Match the axis to the stacked row: plot cell then a value-width spacer, so
       the track still lines up with the bars above it. The name spacer collapses.
       Extra bottom clearance keeps the axis labels clear of the floating
       scroll-to-top button, which sits in the bottom-right corner. */
    .tc-axis{grid-template-columns:1fr var(--val);gap:8px;padding-bottom:56px}
    .tc-axis-spacer{display:none}
  }
</style>
